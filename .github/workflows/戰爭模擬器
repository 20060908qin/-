      panel.appendChild(paragraph);
    }

    // 補給計算：若能透過己方連通格子到達首都，則按距離衰減，否則補給低
    function bfsPath(start, goal, owner){
      const q = [start]; const seen = new Set([`${start.row},${start.col}`]); const parents = {};
      while(q.length){ const cur = q.shift(); if(cur.row===goal.row && cur.col===goal.col) { // build path
          const path = []; let k=`${cur.row},${cur.col}`; while(k){ const [r,c]=k.split(',').map(Number); path.unshift({row:r,col:c}); k = parents[k]; } return path;
        }
        getNeighbors(cur.row,cur.col).forEach(n=>{ if(!n) return; if(n.owner===owner && !seen.has(`${n.row},${n.col}`)){ seen.add(`${n.row},${n.col}`); parents[`${n.row},${n.col}`]=`${cur.row},${cur.col}`; q.push(n); } });
      }
      return null;
    }

    function computeSupplyForCell(cell){
      if(!cell.owner) return 1.0;
      const country = gameState.countryStats[cell.owner];
      if(!country || !country.capital) return 0.6;
      const cap = {row: country.capital.row, col: country.capital.col};
      const path = bfsPath({row:cell.row,col:cell.col}, cap, cell.owner);
      if(!path) return 0.4; // 斷補給
      const dist = path.length - 1;
      const supply = Math.max(0.35, 1 - dist * 0.12);
      return supply;
    }

    function computeCountrySupply(countryName){
      try {
        if (ENABLE_MODULAR_RUNTIME && typeof getCountrySupplyModular === 'function' && window.moduleSystem?.isInitialized) {
          const modularSupply = getCountrySupplyModular(countryName);
          if (Number.isFinite(modularSupply) && modularSupply >= 0) {
            return modularSupply;
          }
        }
      } catch (e) {
        console.warn('模組化補給計算失敗，回退預設計算。', e);
      }

      const country = gameState.countryStats[countryName];
      if (!country) return 0.0;
      if (country.supplyCache && country.supplyCache.turn === gameState.turn) {
        return country.supplyCache.value;
      }

      const cells = [].concat(...WORLD_MAP).filter(c=>c.owner===countryName);
      if(cells.length===0) {
        country.supplyCache = { turn: gameState.turn, value: 0.0 };
        return 0.0;
      }
      const s = cells.reduce((sum,c)=>sum+computeSupplyForCell(c),0)/cells.length;
      country.supplyCache = { turn: gameState.turn, value: s };
      return s;
    }

    function invalidateSupplyCache(names) {
      (names || []).forEach(name => {
        const country = gameState.countryStats[name];
        if (country) country.supplyCache = null;
      });
    }

    // 找出防守方最前線的格子（鄰接任一攻方格子）
    function findFrontlineCells(defenderName, attackerName){
      const flat = [].concat(...WORLD_MAP);
      const defenderCells = flat.filter(c=>c.owner===defenderName);
      const frontline = [];
      defenderCells.forEach(cell=>{
        const neigh = getNeighbors(cell.row, cell.col);
        if(neigh.some(n=>n.owner===attackerName)) frontline.push(cell);
      });
      return frontline;
    }

    // 佔領若干格子，回傳被佔領的格子列表與獲得的資源統計
    function captureMapCells(cellsToCapture, winnerName, defenderName){
      const captured = [];
      const resourcesGained = {};
      const capitalsTaken = [];
      const dirtyCells = [];
      cellsToCapture.forEach(cell=>{
        if(cell.owner === winnerName) return; // 已佔領
        const wasCapital = cell.isCapital;
        if(wasCapital) capitalsTaken.push({row:cell.row,col:cell.col});
        cell.owner = winnerName;
        cell.isCapital = false; // 移除格內首都標示（後續以國家資料處理）
        dirtyCells.push(cell);
        captured.push({cell, wasCapital});
        if(cell.resource){ resourcesGained[cell.resource] = (resourcesGained[cell.resource]||0)+1; }
      });
      // 更新雙方 territoryGrid 與數值
      const winner = gameState.countryStats[winnerName];
      const defender = gameState.countryStats[defenderName];
      if(winner){
        winner.territoryGrid = [].concat(...WORLD_MAP).filter(c=>c.owner===winnerName).map(c=>({row:c.row,col:c.col}));
        winner.territory = winner.territoryGrid.length;
      }
      if(defender){
        defender.territoryGrid = [].concat(...WORLD_MAP).filter(c=>c.owner===defenderName).map(c=>({row:c.row,col:c.col}));
        defender.territory = defender.territoryGrid.length;
        checkDefeatedState(defender);
      }
      invalidateSupplyCache([winnerName, defenderName]);
      return {captured, resourcesGained, capitalsTaken, dirtyCells};
    }

    const gameState = {
      turn: 1,
      selectedCountry: null,
      battleReports: [],
      totalBattles: 0,
      defeatedCountries: [],
      countryStats: {},
      turnOrder: [],
      autoRunning: false,
      autoRunTimer: null,
      simulationSpeed: 1,
      news: [],
      chronicle: [],
      newsVisibleCount: HISTORY_PAGE_SIZE,
      chronicleVisibleCount: HISTORY_PAGE_SIZE,
      rankingCache: null,
      rankingLastUpdatedTurn: 0,
      battleReportsVisibleCount: BATTLE_REPORT_PAGE_SIZE,
      countryListVisible: {
        active: COUNTRY_LIST_PAGE_SIZE,
        exile: COUNTRY_LIST_PAGE_SIZE,
        defeated: COUNTRY_LIST_PAGE_SIZE,
      },
      turnEvents: [],
      warCoalitions: {},
      hegemony: { active: false, leader: null, triggeredTurn: 0 },
      worldEra: { key: 'classical', name: '古典時代', changedTurn: 1 },
      victoryCounters: {},
      victories: {},
      internalEvents: {},
      turnStarted: false,
      civilWars: {},  // 追蹤內戰狀態 {countryName: {governmentForce, rebelForce, battleCount}}
      wonders: {}  // 追蹤世界奇觀 {countryName: [wonderList]}
    };

    const CULTURAL_SPHERES = ['北方文化', '海洋文化', '沙漠文化', '草原文化', '山地文化', '河谷文化'];
    const ETHNIC_GROUPS = ['北境族', '海民', '沙裔', '山民', '平原族', '河谷民'];
    const RELIGIONS = ['太陽信仰', '海神信仰', '祖靈信仰', '天命信仰', '火祀信仰', '世俗主義'];
    
    // === 文明特質系統 ===
    const CIVILIZATION_TRAITS = [
      { name: '軍國傳統', bonus: { soldiers: 0.2, war_exhaustion: 5 } },
      { name: '海洋民族', bonus: { naval: 0.3, territory: 0.15 } },
      { name: '金融中心', bonus: { economy: 0.4, corruption: 5 } },
      { name: '工業強國', bonus: { economy: 0.25, soldiers: 0.15 } },
      { name: '科技先驅', bonus: { research_speed: 0.3, economy: -0.1 } },
      { name: '文化聖地', bonus: { cultural_integration: 10, satisfaction: 5 } },
      { name: '外交樞紐', bonus: { relations: 10, stability: 5 } },
      { name: '農業帝國', bonus: { population: 0.25, stability: 3 } }
    ];
    
    // === 世界奇觀系統 ===
    const WORLD_WONDERS = [
      { name: '長城', effects: { defense: 0.25, stability: 5 }, cost: 100, research: 'gunpowder' },
      { name: '大運河', effects: { economy: 0.3, territory: 0.1 }, cost: 120, research: 'industrial' },
      { name: '巨港', effects: { naval: 0.4, economy: 0.2 }, cost: 80, research: 'gunpowder' },
      { name: '超級工廠', effects: { economy: 0.35, soldiers: 0.1 }, cost: 150, research: 'industrial' },
      { name: '太空中心', effects: { research_speed: 0.4, satisfaction: 8 }, cost: 200, research: 'information' },
      { name: '大圖書館', effects: { research_speed: 0.25, culturalIntegration: 15 }, cost: 110, research: 'industrial' },
      { name: '皇家海軍基地', effects: { naval: 0.5, soldiers: 0.15 }, cost: 130, research: 'gunpowder' },
      { name: '量子研究所', effects: { research_speed: 0.5, economy: -0.05 }, cost: 180, research: 'information' }
    ];
    const WORLD_ERAS = [
      { key: 'classical', name: '古典時代', startYear: 1000, effects: '傳統秩序，地方戰爭為主' },
      { key: 'gunpowder', name: '火藥時代', startYear: 1400, effects: '軍事技術躍進，攻城與征服加速' },
      { key: 'industrial', name: '工業時代', startYear: 1800, effects: '工業爆發，經濟與補給決定國力' },
      { key: 'modern', name: '現代', startYear: 1900, effects: '總體戰與外交聯盟並行' },
      { key: 'information', name: '資訊時代', startYear: 2000, effects: '科技與治理效率成為核心' }
    ];

    function inferCulturalSphereByTerrain(terrain) {
      if (terrain === 'island') return '海洋文化';
      if (terrain === 'desert') return '沙漠文化';
      if (terrain === 'mountain') return '山地文化';
      if (terrain === 'river') return '河谷文化';
      return '北方文化';
    }

    // === 文明特質分配函數 ===
    function assignCivilizationTrait(country) {
      if (country.civilizationTrait) return;
      country.civilizationTrait = CIVILIZATION_TRAITS[Math.floor(Math.random() * CIVILIZATION_TRAITS.length)];
    }
    
    // === 應用文明特質加成 ===
    function applyCivilizationBonus(country) {
      if (!country.civilizationTrait) return;
      const trait = country.civilizationTrait;
      if (trait.bonus.soldiers) country.soldiers = Math.floor(country.soldiers * (1 + trait.bonus.soldiers));
      if (trait.bonus.economy) country.economy = Math.floor(country.economy * (1 + trait.bonus.economy));
      if (trait.bonus.research_speed) country.research_progress = Object.keys(country.research_progress).reduce((acc, t) => {
        acc[t] = country.research_progress[t] * (1 + trait.bonus.research_speed);
        return acc;
      }, {});
      if (trait.bonus.cultural_integration) country.culturalIntegration = Math.min(100, (country.culturalIntegration || 55) + trait.bonus.cultural_integration);
      if (trait.bonus.stability) country.stability = Math.min(100, (country.stability || 50) + trait.bonus.stability);
      if (trait.bonus.war_exhaustion) country.war_exhaustion = Math.max(0, (country.war_exhaustion || 0) - trait.bonus.war_exhaustion);
    }

    function ensureIdentityProfile(state) {
      if (!state) return;
      const terrainSphere = inferCulturalSphereByTerrain(state.terrain);
      state.culturalSphere = state.culturalSphere || terrainSphere;
      state.ethnicity = state.ethnicity || ETHNIC_GROUPS[Math.floor(Math.random() * ETHNIC_GROUPS.length)];
      state.religion = state.religion || RELIGIONS[Math.floor(Math.random() * RELIGIONS.length)];
      state.culturalIntegration = state.culturalIntegration ?? 55;
      state.demilitarizedUntil = state.demilitarizedUntil || 0;
      state.ceasefireTreatyUntil = state.ceasefireTreatyUntil || {};
      state.currentGoal = state.currentGoal || state.long_term_goal;
    }

    function getCulturalRelationBonus(stateA, stateB) {
      if (!stateA || !stateB) return 0;
      let bonus = 0;
      if (stateA.culturalSphere && stateA.culturalSphere === stateB.culturalSphere) bonus += 20;
      if (stateA.religion && stateA.religion === stateB.religion) bonus += 8;
      if (stateA.ethnicity && stateA.ethnicity === stateB.ethnicity) bonus += 5;
      return bonus;
    }

    function computeCulturalFriction(state) {
      if (!state) return 0;
      const cells = getCellsOfCountry(state.name);
      if (!cells.length) return 0;
      const sample = cells.slice(0, Math.min(80, cells.length));
      let conflict = 0;
      let checks = 0;

      sample.forEach(cell => {
        const neighbors = getNeighbors(cell.row, cell.col);
        neighbors.forEach(n => {
          if (!n || !n.owner || n.owner === state.name) return;
          const other = gameState.countryStats[n.owner];
          if (!other) return;
          checks += 1;
          if (other.culturalSphere !== state.culturalSphere) conflict += 1;
          if (other.religion !== state.religion) conflict += 0.5;
        });
      });
      if (checks === 0) return 0;
      return Math.max(0, Math.min(1, conflict / checks));
    }

    function getCurrentEra(year = gameState.year) {
      let current = WORLD_ERAS[0];
      WORLD_ERAS.forEach(era => {
        if (year >= era.startYear) current = era;
      });
      return current;
    }

    function updateWorldEraProgression() {
      const era = getCurrentEra();
      if (!gameState.worldEra || gameState.worldEra.key !== era.key) {
        gameState.worldEra = { key: era.key, name: era.name, changedTurn: gameState.turn };
        addNews(`🌍 世界進入 ${era.name}：${era.effects}`);
        addChronicle(`${formatDateLabel()}：世界進入${era.name}。${era.effects}`);

        // 時代解鎖：科技、政體與事件強度同步變化
        getAliveCountries().forEach(c => {
          const state = gameState.countryStats[c.name];
          if (!state) return;
          ensureIdentityProfile(state);

          if (era.key === 'gunpowder') {
            state.research_progress.gunpowder = (state.research_progress.gunpowder || 0) + 1;
            if ((state.researched_techs || []).includes('gunpowder')) state.soldiers = Math.floor((state.soldiers || 0) * 1.03);
          } else if (era.key === 'industrial') {
            state.research_progress.industrial = (state.research_progress.industrial || 0) + 1;
            state.economy += 3;
            state.cities = Math.max(1, (state.cities || 1) + 1);
          } else if (era.key === 'modern') {
            state.research_progress.aviation = (state.research_progress.aviation || 0) + 1;
            if (state.gov === '帝國' && state.stability < 45 && Math.random() < 0.25) {
              const oldGov = state.gov;
              state.gov = '共和國';
              handleDynastyChange(state, oldGov, state.gov);
            }
          } else if (era.key === 'information') {
            state.research_progress.diplomacy = (state.research_progress.diplomacy || 0) + 1;
            state.corruption = Math.max(0, (state.corruption || 0) - 3);
            state.culturalIntegration = Math.min(100, (state.culturalIntegration || 50) + 6);
          }
        });
      }
      return gameState.worldEra;
    }

    function setTimedCeasefire(countryA, countryB, months, reason = '停戰協定') {
      const stateA = gameState.countryStats[countryA];
      const stateB = gameState.countryStats[countryB];
      if (!stateA || !stateB) return;
      ensureIdentityProfile(stateA);
      ensureIdentityProfile(stateB);

      const untilTurn = gameState.turn + Math.max(1, months);
      stateA.ceasefireTreatyUntil[countryB] = untilTurn;
      stateB.ceasefireTreatyUntil[countryA] = untilTurn;
      if (!stateA.ceasefires.includes(countryB)) stateA.ceasefires.push(countryB);
      if (!stateB.ceasefires.includes(countryA)) stateB.ceasefires.push(countryA);
      stateA.enemies = stateA.enemies.filter(n => n !== countryB);
      stateB.enemies = stateB.enemies.filter(n => n !== countryA);
      clearWarCoalition(countryA, countryB);
      addNews(`${countryA} 與 ${countryB} 簽訂 ${months} 個月${reason}。`);
    }

    function evaluateWorldHegemony(ranking) {
      if (!ranking || ranking.length < 2) return;
      const first = ranking[0];
      const second = ranking[1];
      const threshold = second.power * 1.5;
      const active = gameState.hegemony?.active;

      if (first.power > threshold) {
        if (!active || gameState.hegemony.leader !== first.name) {
          gameState.hegemony = { active: true, leader: first.name, triggeredTurn: gameState.turn };
          addNews(`👑 世界霸權時代：${first.name} 的國力遠超列強，反霸權聯盟開始結成。`);
          addChronicle(`${formatDateLabel()}：世界霸權時代開啟，${first.name} 成為頭號霸權。`);
        }

        const hegemon = gameState.countryStats[first.name];
        const antiBloc = getAliveCountries().filter(c => c.name !== first.name && c.status !== 'defeated');
        antiBloc.forEach(member => {
          const state = gameState.countryStats[member.name];
          if (!state) return;
          state.currentGoal = '遏制霸權';
          if (!state.enemies.includes(first.name)) state.enemies.push(first.name);
          state.ceasefires = state.ceasefires.filter(n => n !== first.name);
          modifyRelation(state.name, first.name, -8);
          modifyRelation(first.name, state.name, -6);
        });

        for (let i = 0; i < antiBloc.length; i++) {
          for (let j = i + 1; j < antiBloc.length; j++) {
            const a = antiBloc[i].name;
            const b = antiBloc[j].name;
            if (getRelation(a, b) < 45) modifyRelation(a, b, 10);
            if (getRelation(b, a) < 45) modifyRelation(b, a, 10);
            const stateA = gameState.countryStats[a];
            if (stateA && !stateA.allies.includes(b) && Math.random() < 0.35) {
              formAlliance(a, b);
            }
          }
        }

        if (hegemon) hegemon.currentGoal = '維持霸權';
      } else if (active && gameState.turn - (gameState.hegemony.triggeredTurn || 0) > 18) {
        addNews(`⚖️ 世界霸權時代降溫：${gameState.hegemony.leader} 的領先優勢被削弱。`);
        gameState.hegemony = { active: false, leader: null, triggeredTurn: 0 };
      }
    }

    function shuffle(array) {
      for (let i = array.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [array[i], array[j]] = [array[j], array[i]];
      }
      return array;
    }

    
    function getCountriesByStatus(statusArray) {
      if (!Array.isArray(statusArray)) statusArray = [statusArray];
      return Object.values(gameState.countryStats || {}).filter(s => s && statusArray.includes(s.status));
    }
    
    function getAllCountries() {
      return Object.values(gameState.countryStats || {}).filter(s => s);
    }

    function ensureRelationsMap(state) {
      if (!state) return new Map();
      if (state.relations instanceof Map) return state.relations;
      state.relations = new Map(Object.entries(state.relations || {}));
      return state.relations;
    }
    
    function getCountriesNotDefeated() {
      return getCountriesByStatus(['active', 'vassal', 'exile']);
    }
    
    function getAliveCountries() {
      return getCountriesByStatus(['active', 'vassal', 'exile']);
    }

    function checkDefeatedState(state) {
      if (!state || state.status === 'defeated' || state.status === 'exile') return;
      if ((state.territory || 0) === 0) {
        state.status = 'defeated';
        state.relations = new Map();
        state.allies = [];
        state.enemies = [];
        state.ceasefires = [];
        state.tributaries = [];
        state.memory = {};
        Object.values(gameState.countryStats).forEach(other => {
          if (!other || other.name === state.name) return;
          if (other.relations instanceof Map) other.relations.delete(state.name);
          else if (other.relations) delete other.relations[state.name];
          other.allies = (other.allies || []).filter(n => n !== state.name);
          other.enemies = (other.enemies || []).filter(n => n !== state.name);
          other.ceasefires = (other.ceasefires || []).filter(n => n !== state.name);
          other.tributaries = (other.tributaries || []).filter(n => n !== state.name);
          if (other.suzerain === state.name) other.suzerain = null;
        });
        if (!gameState.defeatedCountries.includes(state.name)) {
          gameState.defeatedCountries.push(state.name);
        }
        addNews(`${state.name} 暴失所有領土，正式滅亡。`);
        recordCountryDeath(state.name, 'zero_territory', null);
        archiveCountry(state.name);
      }
    }

    function getExileGovernments() {
      return getCountriesByStatus('exile');
    }

    function getVisibleCountries() {
      return getCountriesNotDefeated();
    }

    function _safeId(name) {
      return String(name).replace(/[^a-zA-Z0-9_-]/g, '_');
    }

    function getHistoryRecords(name) {
      const history = { birth: null, death: null };
      if (gameState.history && gameState.history.births && gameState.history.births[name]) {
        history.birth = gameState.history.births[name];
      }
      if (gameState.history && gameState.history.deaths && Array.isArray(gameState.history.deaths)) {
        // 取最後一條與該國家有關的死亡紀錄
        for (let i = gameState.history.deaths.length - 1; i >= 0; i--) {
          const d = gameState.history.deaths[i];
          if (d && d.name === name) { history.death = d; break; }
        }
      }
      return history;
    }


    function handleExileState(state) {
      if (!state || state.status !== 'exile') return;
      state.exile_months = (state.exile_months || 0) + 1;
      const currentCells = getCellsOfCountry(state.name).length;
      state.territory = currentCells;

      if (currentCells > 0) {
        state.status = 'active';
        state.exile_supporter = null;
        state.exile_months = 0;
        addNews(`${state.name} 成功復國，重新回到世界舞台。`);
        return;
      }

      if (state.exile_supporter) {
        const supporter = gameState.countryStats[state.exile_supporter];
        if (!supporter || supporter.status === 'defeated') {
          state.exile_supporter = null;
          addNews(`${state.name} 原支持國已滅亡，流亡政府失去依靠。`);
        }
      }

      if (!state.exile_supporter) {
        const candidates = getAliveCountries().filter(c => c.name !== state.name);
        if (candidates.length > 0) {
          const host = candidates[Math.floor(Math.random() * candidates.length)];
          state.exile_supporter = host.name;
          addNews(`${state.name} 轉移流亡政府至 ${host.name}。`);
        } else if (Math.random() < 0.5) {
          state.status = 'defeated';
          state.relations = new Map();
          state.allies = [];
          state.enemies = [];
          state.ceasefires = [];
          state.tributaries = [];
          state.memory = {};
          if (!gameState.defeatedCountries.includes(state.name)) {
            gameState.defeatedCountries.push(state.name);
          }
          addNews(`${state.name} 因無法取得新支持國，正式滅亡。`);
          recordCountryDeath(state.name, 'extinct', null);
          archiveCountry(state.name);
          return;
        }
      }

      // 360 月絕對消亡（無例外）
      if (state.exile_months >= 360) {
        state.status = 'defeated';
        state.relations = new Map();
        state.allies = [];
        state.enemies = [];
        state.ceasefires = [];
        state.tributaries = [];
        state.memory = {};
        if (!gameState.defeatedCountries.includes(state.name)) {
          gameState.defeatedCountries.push(state.name);
        }
        addNews(`${state.name} 經過 360 月長期流亡，最終消亡於歷史。`);
        recordCountryDeath(state.name, 'extinct_permanent', null);
        archiveCountry(state.name);
        return;
      }

      if (state.exile_months >= 240) {
        const roll = Math.random();
        if (roll < 0.7) {
          state.status = 'defeated';
          state.relations = new Map();
          state.allies = [];
          state.enemies = [];
          state.ceasefires = [];
          state.tributaries = [];
          state.memory = {};
          if (!gameState.defeatedCountries.includes(state.name)) {
            gameState.defeatedCountries.push(state.name);
          }
          addNews(`${state.name} 經過長期流亡後，最終正式滅亡。`);
          recordCountryDeath(state.name, 'extinct', null);
          archiveCountry(state.name);
        } else if (roll < 0.9) {
          addNews(`${state.name} 雖然流亡多年，仍堅守流亡政府。`);
        } else {
          const candidates = getAliveCountries().filter(c => c.name !== state.name);
          if (candidates.length > 0) {
            const host = candidates[Math.floor(Math.random() * candidates.length)];
            state.exile_supporter = host.name;
            addNews(`${state.name} 轉移流亡政府至 ${host.name} 以求生存。`);
          }
        }
      }
    }

    function prepareTurn() {
      const alive = getAliveCountries();
      gameState.turnOrder = shuffle(alive.map(c => c.name));
    }

    function triggerGreatCivilWar(state) {
      if (!state || state.status !== 'active') return false;
      // 叛軍派系不再二次觸發內戰，避免「叛軍叛軍」連鎖命名
      if ((state.name || '').includes('叛軍')) return false;

      // 同一政權同時只允許一場內戰
      if (gameState.civilWars && gameState.civilWars[state.name]) return false;

      const baseName = (state.name || '').replace(/叛軍\d*$/u, '');
      const existingRebel = getAllCountries().find(s =>
        s && s.name && s.name.startsWith(`${baseName}叛軍`) && s.status !== 'defeated'
      );
      if (existingRebel) return false;

      const worldClaimed = Math.max(1, [].concat(...WORLD_MAP).filter(cell => cell.owner).length);
      const territoryShare = (state.territory || 0) / worldClaimed;
      const culturalFriction = computeCulturalFriction(state);

      // 新的內戰觸發條件：穩定度 < 60 AND 滿意度低 < 50
      const lowStability = (state.stability || 50) < 60;
      const lowSatisfaction = (state.satisfaction || 50) < 50;
      
      if (lowStability && lowSatisfaction) {
        // 有機會觸發內戰
        const internalWarChance = Math.max(0.03, Math.min(0.15,
          (60 - (state.stability || 50)) / 100 + (50 - (state.satisfaction || 50)) / 100
        ));
        if (Math.random() > internalWarChance) {
          return false;
        }
      } else if ((state.territory || 0) < 90 || (state.stability || 50) > 36 || (state.war_exhaustion || 0) < 60) {
        // 舊的分裂條件
        return false;
      }

      const originalName = state.name;
      
      // 創建叛軍力量
      const rebelPower = Math.max(10, Math.floor((state.soldiers || 100) * 0.4));
      const governmentPower = Math.max(20, (state.soldiers || 100) - rebelPower);
      
      // 叛軍名稱
      let rebelName = `${baseName}叛軍`;
      if (gameState.countryStats[rebelName] && gameState.countryStats[rebelName].status !== 'defeated') {
        let seq = 2;
        while (gameState.countryStats[`${baseName}叛軍${seq}`] && gameState.countryStats[`${baseName}叛軍${seq}`].status !== 'defeated') {
          seq += 1;
        }
        rebelName = `${baseName}叛軍${seq}`;
      }
      
      // 初始化內戰狀態
      gameState.civilWars[originalName] = {
        rebelForce: rebelName,
        governmentForce: originalName,
        battleCount: 0,
        duration: 0,
        maxDuration: Math.max(12, Math.min(60, Math.floor(Math.random() * 36 + 12)))
      };
      
      // 從主國分出叛軍領土
      if ((state.territory || 0) > 5) {
        const rebelTerritory = Math.max(2, Math.floor((state.territory || 10) * (0.25 + Math.random() * 0.15)));
        const rebelCountry = createNewCountryFromSplit(originalName, rebelTerritory);
        
        if (rebelCountry) {
          // 重新命名為叛軍
          if (rebelCountry !== rebelName) {
            renameCountry(rebelCountry, rebelName);
          }
          
          const rebelState = gameState.countryStats[rebelName];
          if (rebelState) {
            rebelState.soldiers = rebelPower;
            rebelState.status = 'active';
            rebelState.long_term_goal = '推翻統治';
            rebelState.strategy = 'vengeful';
            rebelState.enemies = [originalName];
            rebelState.stability = Math.max(20, state.stability - 15);
            
            // 叛軍對政府的仇恨
            modifyRelation(rebelName, originalName, -50);
            modifyRelation(originalName, rebelName, -40);
          }
          
          // 政府軍狀態更新
          state.soldiers = governmentPower;
          state.enemies = [rebelName];
          state.stability = Math.max(10, state.stability - 25);
          state.satisfaction = Math.max(0, (state.satisfaction || 50) - 30);
          state.war_exhaustion = Math.min(100, (state.war_exhaustion || 0) + 20);
          
          addNews(`🔥 ${originalName} 爆發內戰！政府軍與${rebelName}進入戰爭狀態！`);
          addChronicle(`${formatDateLabel()}：${originalName} 內戰爆發！政府軍與叛軍分裂對立。`);
          renderCountryList();
          renderMapGrid();
          return true;
        }
      }
      
      // 備選：傳統分裂方式
      const fragments = ['北', '南', '自由'];
      const maxSplits = Math.min(3, Math.max(2, Math.floor((state.territory || 0) / 80)));
      const created = [];

      for (let i = 0; i < maxSplits; i++) {
        const takeCount = Math.max(4, Math.floor(state.territory * (0.12 + Math.random() * 0.08)));
        const rawName = createNewCountryFromSplit(originalName, takeCount);
        if (!rawName) break;

        const targetName = `${fragments[i] || '新'}${originalName}`;
        let finalName = targetName;
        let seq = 2;
        while (gameState.countryStats[finalName]) {
          if (finalName === rawName) break;
          finalName = `${targetName}${seq++}`;
        }
        if (finalName !== rawName) renameCountry(rawName, finalName);

        const newState = gameState.countryStats[finalName];
        if (newState) {
          newState.stability = Math.max(20, (newState.stability || 50) - 8);
          newState.war_exhaustion = Math.min(100, (newState.war_exhaustion || 0) + 12);
          newState.long_term_goal = '獨立維持';
          newState.strategy = 'defensive';
        }
        created.push(finalName);
      }

      if (created.length > 0) {
        state.stability = Math.max(5, (state.stability || 20) - 20);
        state.war_exhaustion = Math.min(100, (state.war_exhaustion || 0) + 15);
        state.satisfaction = Math.max(0, (state.satisfaction || 50) - 20);
        addNews(`🔥 ${originalName} 爆發大內戰，分裂為：${created.join('、')}！`);
        addChronicle(`${formatDateLabel()}：${originalName} 爆發大內戰，政權崩解為 ${created.join('、')}。`);
        renderCountryList();
        renderMapGrid();
        return true;
      }
      return false;
    }

    function applyRoundEffects() {
      updateWorldEraProgression();
      const worldClaimed = Math.max(1, [].concat(...WORLD_MAP).filter(cell => cell.owner).length);

      const aliveStates = getAliveCountries()
        .map(c => gameState.countryStats[c.name])
        .filter(Boolean);
      const maxEconomyThisRound = aliveStates.length ? Math.max(...aliveStates.map(s => s.economy || 0)) : 0;
      const avgTerritory = aliveStates.length ? aliveStates.reduce((sum, s) => sum + (s.territory || 0), 0) / aliveStates.length : 1;
      const avgEconomy = aliveStates.length ? aliveStates.reduce((sum, s) => sum + (s.economy || 0), 0) / aliveStates.length : 1;

      aliveStates.forEach(state => {
        if (!state) return;
        ensureIdentityProfile(state);

        // === 黑暗時代系統 ===
        if (!state.darkAge) {
          state.darkAge = { inDarkAge: false, duration: 0 };
        }
        
        // 觸發黑暗時代
        triggerDarkAge(state);
        
        // 應用黑暗時代效果
        applyDarkAgeEffects(state);

        // === 黃金時代系統 ===
        if (!state.goldenAge) {
          state.goldenAge = { economicLeaderMonths: 0, inGoldenAge: false, goldenAgeStart: null, goldenAgeDuration: 0 };
        }
        
        // 檢查是否經濟第一（回合級預計算，降低計算量）
        const isEconomicLeader = (state.economy || 0) >= maxEconomyThisRound;
        
        if (isEconomicLeader) {
          state.goldenAge.economicLeaderMonths += 1;
          if (state.goldenAge.economicLeaderMonths >= 120 && !state.goldenAge.inGoldenAge) {
            // 觸發黃金時代
            state.goldenAge.inGoldenAge = true;
            state.goldenAge.goldenAgeStart = gameState.turn;
            state.goldenAge.goldenAgeDuration = 120;  // 10 年黃金時代
            addNews(`✨ ${state.name} 進入黃金時代！經濟、科技、人口迎來黃金發展期！`);
            addChronicle(`${formatDateLabel()}：${state.name} 因經濟連續繁榮10年，進入黃金時代！`);
            // 記錄到永久歷史
            if (!gameState.worldHistory) gameState.worldHistory = {};
            if (!gameState.worldHistory.goldenAges) gameState.worldHistory.goldenAges = [];
            gameState.worldHistory.goldenAges.push({
              country: state.name,
              startYear: gameState.year,
              startMonth: gameState.month
            });
          }
        } else {
          state.goldenAge.economicLeaderMonths = 0;  // 重置計數
        }
        
        // 黃金時代效果應用
        if (state.goldenAge.inGoldenAge) {
          state.goldenAge.goldenAgeDuration -= 1;
          // 科技加速：研究進度 +30%
          Object.keys(state.research_progress).forEach(tech => {
            state.research_progress[tech] *= 1.3;
          });
          // 人口加成：+20%
          state.population = Math.floor(state.population * 1.002);  // 每月額外 0.2%
          // 文化加成：+20%
          state.culturalIntegration = Math.min(100, state.culturalIntegration + 0.2);
          
          if (state.goldenAge.goldenAgeDuration <= 0) {
            state.goldenAge.inGoldenAge = false;
            addNews(`${state.name} 的黃金時代落幕，回歸常態發展。`);
          }
        }
        
        // 應用世界奇觀效果
        applyWonderEffects(state);

        if ((state.demilitarizedUntil || 0) > gameState.turn) {
          state.stability = Math.min(100, (state.stability || 50) + 0.4);
        }

        // 大內戰：高疲勞 + 超低穩定的大帝國可能瞬間分裂
        if (triggerGreatCivilWar(state)) {
          return;
        }
        
        // 戰爭疲勞、民心、腐敗恢復
        if ((state.enemies || []).length > 0) state.war_exhaustion = Math.min(100, (state.war_exhaustion || 0) + 1.2);
        else state.war_exhaustion = Math.max(0, (state.war_exhaustion || 0) - 2);
        state.satisfaction = Math.min(100, state.satisfaction + 1);
        state.corruption = Math.max(0, state.corruption - 1);
        
        // 經濟收入
        state.economy += calculateEconomicIncome(state);

        // 大帝國維護成本：領土/軍隊越大，維持成本越重
        const empireMaintenance = (state.territory || 0) * 0.05 + (state.soldiers || 0) * 0.02 + (state.elite_soldiers || 0) * 0.03;
        state.economy -= empireMaintenance;

        // 軍費維護（平衡核心）：100兵每月約消耗1經濟
        const militaryUpkeep = ((state.soldiers || 0) + (state.elite_soldiers || 0) * 1.5) / 100;
        state.economy -= militaryUpkeep;

        // 戰爭疲勞分段懲罰
        let recruitMultiplier = 1;
        if ((state.war_exhaustion || 0) >= 30) state.economy *= 0.9;
        if ((state.war_exhaustion || 0) >= 50) recruitMultiplier *= 0.5;
        if ((state.war_exhaustion || 0) >= 70) {
          state.stability = Math.max(0, (state.stability || 50) - 2);
          state.satisfaction = Math.max(0, (state.satisfaction || 50) - 2);
        }
        if ((state.war_exhaustion || 0) >= 90) {
          state.stability = Math.max(0, (state.stability || 50) - 3);
          if (Math.random() < 0.06) {
            addNews(`⚠ ${state.name} 因極端戰爭疲勞爆發革命危機。`);
            state.satisfaction = Math.max(0, (state.satisfaction || 50) - 10);
          }
        }

        // 經濟破產懲罰：軍隊減員 + 民心下降
        if (state.economy < 1) {
          const deficit = 1 - state.economy;
          const attritionRate = Math.min(0.35, 0.05 + deficit / 20);
          const lostSoldiers = Math.floor((state.soldiers || 0) * attritionRate);
          state.soldiers = Math.max(50, (state.soldiers || 0) - lostSoldiers);
          state.satisfaction = Math.max(0, (state.satisfaction || 50) - Math.ceil(deficit * 3) - 2);
          if (lostSoldiers > 0 && Math.random() < 0.22) {
            addNews(`${state.name} 因軍費不足被迫裁軍 ${lostSoldiers} 人。`);
          }
          state.economy = 1;
        } else {
          state.economy = Math.max(1, state.economy);
        }

        // 追趕機制：落後國獲得溫和成長，降低滾雪球，提升翻盤機率
        const territoryRatio = (state.territory || 0) / Math.max(1, avgTerritory);
        const economyRatio = (state.economy || 0) / Math.max(1, avgEconomy);
        const soldierCount = (state.soldiers || 0) + (state.elite_soldiers || 0);
        const avgSoldiers = aliveStates.reduce((s, c) => s + (c.soldiers || 0) + (c.elite_soldiers || 0), 0) / Math.max(1, aliveStates.length);
        const soldierRatio = soldierCount / Math.max(1, avgSoldiers);
        const underdogRatio = Math.max(0, Math.min(1, 1 - Math.min(territoryRatio, economyRatio, soldierRatio)));
        if (underdogRatio > 0.15) {
          // 經濟追趕（更強）
          state.economy += 1.2 + underdogRatio * 2.4;
          // 士兵追趕：弱小國自然徵兵補充
          const soldierCatchup = Math.floor(underdogRatio * 4);
          if (soldierCatchup > 0 && state.economy > 2) {
            state.soldiers = (state.soldiers || 0) + soldierCatchup;
          }
          state.stability = Math.min(100, (state.stability || 50) + 0.3 + underdogRatio * 0.6);
          state.satisfaction = Math.min(100, (state.satisfaction || 50) + 0.3 + underdogRatio * 0.6);
          state.corruption = Math.max(0, (state.corruption || 0) - (0.2 + underdogRatio * 0.4));
        }

        // 霸權摩擦：超大型強權承受額外治理壓力
        if (territoryRatio > 1.8 && economyRatio > 1.5) {
          state.corruption = Math.min(100, (state.corruption || 0) + 0.8);
          state.war_exhaustion = Math.min(100, (state.war_exhaustion || 0) + 0.5);
        }

        // 領土過大造成治理壓力，直接侵蝕穩定度
        const overExpansionPenalty = (state.territory || 0) / 35;
        state.stability = Math.max(0, state.stability - overExpansionPenalty);

        // === 民族/宗教叛亂系統 ===
        const culturalIntegration = state.culturalIntegration || 55;
        if (culturalIntegration < 35) {
          // 文化融合度低時觸發叛亂
          const rebellionChance = (35 - culturalIntegration) / 100;  // 最多 35%
          if (Math.random() < rebellionChance * 0.02) {  // 每月觸發概率
            const rebellionTypes = [];
            // 如果該國有多族群，容易民族起義
            if (state.ethnicity && state.population > 100) {
              rebellionTypes.push('民族起義');
            }
            // 如果該國有多宗教信仰，容易宗教暴動
            if (state.religion && state.satisfaction < 50) {
              rebellionTypes.push('宗教暴動');
            }
            // 領土過多時容易地方獨立
            if (state.territory > 5) {
              rebellionTypes.push('地方獨立運動');
            }
            if (rebellionTypes.length > 0) {
              const rebellion = rebellionTypes[Math.floor(Math.random() * rebellionTypes.length)];
              const rebelliousPopulation = Math.floor((state.population || 100) * 0.03);
              state.soldiers = Math.max(50, (state.soldiers || 100) - rebelliousPopulation);
              state.stability = Math.max(0, state.stability - 8);
              state.satisfaction = Math.max(0, state.satisfaction - 12);
              addNews(`⚠ ${state.name} 爆發${rebellion}！損失${rebelliousPopulation}名士兵。`);
            }
          }
        }

        // === 大帝國衰退機制 ===
        const worldTerritory = [].concat(...WORLD_MAP).filter(cell => cell.owner).length;
        const imperialPercentage = ((state.territory || 0) / Math.max(1, worldTerritory)) * 100;
        if (imperialPercentage > 35) {
          // 帝國規模超過35%世界領土時開始衰退
          const declineIntensity = (imperialPercentage - 35) / 65;  // 0-1 比例
          
          // 腐敗增加
          state.corruption = Math.min(100, (state.corruption || 20) + declineIntensity * 0.5);
          
          // 戰爭疲勞增加
          state.war_exhaustion = Math.min(100, (state.war_exhaustion || 20) + declineIntensity * 0.8);
          
          // 獨立傾向（邊遠領土有機率叛亂）
          if (Math.random() < declineIntensity * 0.01) {
            // 有機會分裂邊遠領土
            const vassalChance = declineIntensity * 0.15;
            if (Math.random() < vassalChance && (state.territory || 0) > 8) {
              const takeCount = Math.max(2, Math.floor((state.territory || 10) * 0.08));
              const newCountry = createNewCountryFromSplit(state.name, takeCount);
              if (newCountry) {
                addNews(`🔄 ${state.name} 因帝國治理危機損失邊遠領土，${newCountry.name}獨立！`);
              }
            }
          }
          
          // 穩定度下降
          state.stability = Math.max(0, state.stability - declineIntensity * 1.2);
        }

        // 異文化接壤摩擦：異文化邊疆越多，叛亂風險越高
        const culturalFriction = computeCulturalFriction(state);
        state.culturalIntegration = Math.max(0, Math.min(100,
          (state.culturalIntegration || 55) + (state.satisfaction > 55 ? 0.7 : 0.3) - culturalFriction * 1.6
        ));
        if (culturalFriction > 0.35) {
          state.stability = Math.max(0, state.stability - culturalFriction * 2.4);
        }
        
        // === 獨立防禦加成（新分裂國有5年防禦優勢） ===
        if ((state.independent_defense_until || 0) > gameState.turn) {
          // 防禦方在戰鬥中獲得加成，在此暫時記錄標記
          // (在 makeBattle 中檢查此字段用於計算)
        }
        
        // === 內戰系統：內戰進行中的自動戰鬥 ===
        if (gameState.civilWars[state.name]) {
          const war = gameState.civilWars[state.name];
          const rebelName = war.rebelForce;
          const rebelState = gameState.countryStats[rebelName];
          
          if (rebelState && rebelState.status === 'active') {
            war.duration += 1;
            war.battleCount += 1;
            
            // 內戰戰鬥
            const govPower = getCombatPower(state);
            const rebPower = getCombatPower(rebelState);
            const govWins = govPower >= rebPower;
            
            if (govWins) {
              rebelState.soldiers = Math.max(5, Math.floor(rebelState.soldiers * 0.85));
              state.soldiers = Math.max(10, Math.floor(state.soldiers * 0.9));
              rebelState.war_exhaustion = Math.min(100, rebelState.war_exhaustion + 8);
              state.war_exhaustion = Math.min(100, state.war_exhaustion + 6);
            } else {
              state.soldiers = Math.max(5, Math.floor(state.soldiers * 0.8));
              rebelState.soldiers = Math.max(10, Math.floor(rebelState.soldiers * 0.9));
              state.war_exhaustion = Math.min(100, state.war_exhaustion + 8);
              rebelState.war_exhaustion = Math.min(100, rebelState.war_exhaustion + 6);
            }
            
            // 內戰結束條件
            if (war.duration >= war.maxDuration || rebelState.soldiers < 10 || state.soldiers < 10) {
              if (govWins || state.soldiers >= rebelState.soldiers * 2) {
                addNews(`✓ ${state.name}政府軍擊潰叛軍，內戰結束！`);
                rebelState.status = 'exile';
                rebelState.exile_supporter = state.name;
                rebelState.exile_months = 0;
              } else {
                addNews(`✗ 叛軍推翻${state.name}政府，建立新政權！`);
                state.status = 'exile';
                state.exile_supporter = rebelName;
                state.exile_months = 0;
              }
              delete gameState.civilWars[state.name];
              state.enemies = state.enemies.filter(e => e !== rebelName);
              rebelState.enemies = rebelState.enemies.filter(e => e !== state.name);
            }
          } else {
            delete gameState.civilWars[state.name];
          }
        }
        // 招募士兵
        const newSoldiers = Math.floor(calculateRecruitment(state) * recruitMultiplier);
        state.soldiers = Math.min(state.soldiers + newSoldiers, state.population * 2);
        
        // 人口承載量（領土 * 20 + 城市 * 10）
        const carryingCapacity = state.territory * 20 + (state.cities || 5) * 10;
        
        // 人口自然成長（每月基礎 0.15%），會被戰爭疲勞、科技、承載量影響
        const baseGrowth = 0.0015; // 0.15% per month
        let growthRate = baseGrowth;
        if (state.researched_techs && state.researched_techs.includes('medicine')) {
          growthRate += 0.002; // 醫療技術提升生育/存活
        }
        // 戰爭疲勞會降低人口成長
        growthRate -= Math.min(0.004, state.war_exhaustion / 10000);
        
        // 承載量限制：人口越接近承載量，成長率越低
        const capacityRatio = state.population / Math.max(1, carryingCapacity);
        if (capacityRatio > 1) {
          // 超過承載量會導致人口衰減
          growthRate -= Math.min(0.005, (capacityRatio - 1) * 0.01);
        } else if (capacityRatio > 0.8) {
          // 接近承載量時成長率大幅下降
          growthRate *= (1 - (capacityRatio - 0.8) * 2);
        }
        
        const popGain = Math.floor(Math.max(state.population * growthRate, -state.population * 0.01)); // 最多衰減 1%
        state.population = Math.max(1, state.population + popGain);
        
        // 停戰協議期滿檢查（條約版）
        state.ceasefires = state.ceasefires.filter(c2 => {
          const untilTurn = state.ceasefireTreatyUntil?.[c2] || 0;
          if (untilTurn > gameState.turn) return true;
          if (untilTurn > 0) {
            if (state.ceasefireTreatyUntil) delete state.ceasefireTreatyUntil[c2];
            addNews(`${state.name}與${c2}的停戰條約到期。`);
            return false;
          }
          if (Math.random() < 0.004) {
            addNews(`${state.name}與${c2}的停戰協議已失效。`);
            return false;
          }
          return true;
        });
        
        // 內政事件
        triggerInternalEvent(state);
        
        // 領袖變更檢查
        checkLeaderDeath(state);
        
        // 盟友關係維持或增強
        state.allies.forEach(ally => {
          modifyRelation(state.name, ally, 1);
        });

        // 更新領土紀錄
        const currentCells = getCellsOfCountry(state.name).length;
        state.territory = currentCells;
        checkDefeatedState(state);

        // 附庸獨立機制：每月檢查獨立條件
        if (state.status === 'vassal' && state.suzerain) {
          const suzerain = gameState.countryStats[state.suzerain];
          if (suzerain && suzerain.status !== 'defeated') {
            // 條件：穩定度 > 70 AND 與宗主關係 < 30 AND 隨機事件（2% 月機率）
            const relationToSuzerain = getRelation(state.name, state.suzerain);
            if (state.stability > 70 && relationToSuzerain < 30 && Math.random() < 0.02) {
              state.status = 'active';
              const oldSuzerain = state.suzerain;
              state.suzerain = null;
              addNews(`${state.name} 宣布獨立，脫離 ${oldSuzerain} 的統治！`);
              addChronicle(`${formatDateLabel()}：${state.name} 獨立。穩定度 ${state.stability}，與宗主關係 ${relationToSuzerain}。`);
            }
          } else if (!suzerain || suzerain.status === 'defeated') {
            // 宗主滅亡，自動獨立
            state.status = 'active';
            const oldSuzerain = state.suzerain;
            state.suzerain = null;
            addNews(`${state.name} 的宗主國 ${oldSuzerain} 已滅亡，自動獲得獨立。`);
          }
        }

        // 大國分裂：領土佔世界過高 + 低穩定 + 高疲勞時顯著提高分裂機率
        const territoryShare = (state.territory || 0) / worldClaimed;
        if (state.stability < 45 && state.territory >= 60 && Object.keys(gameState.countryStats).length < 30) {
          let splitChance = 0.004;
          if (territoryShare > 0.2 && state.stability < 40 && (state.war_exhaustion || 0) > 60) {
            splitChance += 0.02 + Math.max(0, territoryShare - 0.2) * 0.12 + culturalFriction * 0.03;
          }
          if (Math.random() < splitChance) {
            const takeCount = Math.max(3, Math.floor(state.territory * (0.2 + Math.random()*0.15)));
            const newName = createNewCountryFromSplit(state.name, takeCount);
            if (newName) {
              // 調整父國資源與人口
              state.population = Math.max(1, Math.floor(state.population * 0.75));
              state.economy = Math.max(1, Math.floor(state.economy * 0.8));
              state.cities = Math.max(1, Math.floor(state.cities * 0.8));
              state.soldiers = Math.max(1, Math.floor(state.soldiers * 0.7));
              state.elite_soldiers = Math.max(0, Math.floor(state.elite_soldiers * 0.7));
              state.stability = Math.max(10, state.stability - 15);
              state.territory = getCellsOfCountry(state.name).length;
              addChronicle(`${formatDateLabel()}：${state.name} 分裂出 ${newName}。`);
              renderCountryList();
              renderMapGrid();
            }
          }
        }

        // 政體演化檢查
        checkGovernmentEvolution(state);
      });
      
      // 檢查勝利條件
      checkVictory();
      getExileGovernments().forEach(handleExileState);
    }

    function addNews(msg) {
      const entry = `${formatDateLabel()}：${msg}`;
      gameState.news.push(entry);
      gameState.turnEvents.push(msg);
    }
    
    // ===== S級：全球事件系統 =====
    const GLOBAL_EVENTS = {
      cold_war: { name: '冷戰時代', color: '#3498db', effects: '宣戰機率 -30%, 科技研究 +20%' },
      peace_boom: { name: '和平繁榮期', color: '#27ae60', effects: '戰爭 -40%, 經濟 +30%, 人口 +20%' },
      depression: { name: '大蕭條', color: '#e74c3c', effects: '經濟 -40%, 民心 -30%' },
