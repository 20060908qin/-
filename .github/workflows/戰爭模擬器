              b.style.pointerEvents = 'none';
              document.body.appendChild(b);
            } catch(e) { /* ignore */ }
          }

          if (document.readyState === 'complete' || document.readyState === 'interactive') addBadge();
          else document.addEventListener('DOMContentLoaded', addBadge);
        } catch(e) { /* ignore */ }
