    function triggerGlobalEvent() {
      // 5% 概率每回合触发新事件
      if (Math.random() > 0.95) {
        const eventKeys = Object.keys(GLOBAL_EVENTS);
        const eventKey = eventKeys[Math.floor(Math.random() * eventKeys.length)];
        const event = GLOBAL_EVENTS[eventKey];
        gameState.currentEvent = { key: eventKey, ...event, duration: 20 + Math.floor(Math.random() * 40) };
        gameState.eventTurnsRemaining = gameState.currentEvent.duration;
        addNews(`⚡ 全球進入 ${event.name}！`);
        return event;
      } else if (gameState.eventTurnsRemaining && gameState.eventTurnsRemaining > 0) {
        gameState.eventTurnsRemaining--;
        if (gameState.eventTurnsRemaining <= 0) {
          gameState.currentEvent = null;
          addNews('全球事件結束，回歸正常。');
        }
      }
      return gameState.currentEvent;
    }
    
    // ===== S級：世界排行榜系統 =====
    function calculateNationalPower(country) {
      // 綜合評分：軍力30%, 經濟25%, 領土20%, 人口15%, 科技10%
      const militaryScore = Math.min(100, (country.soldiers || 0) / 2);
      const economyScore = Math.min(100, country.economy || 0);
      const territoryScore = Math.min(100, (country.territory || 0) / 2);
      const populationScore = Math.min(100, (country.population || 0) * 0.5);
      const techScore = Math.min(100, (country.researched_techs ? country.researched_techs.length : 0) * 3);
      
      return Math.floor(
        militaryScore * 0.30 +
        economyScore * 0.25 +
        territoryScore * 0.20 +
        populationScore * 0.15 +
        techScore * 0.10
      );
    }
    
    function updateWorldRanking(force = false) {
      const shouldRefresh = force || !gameState.rankingCache || (gameState.turn - (gameState.rankingLastUpdatedTurn || 0) >= RANKING_UPDATE_INTERVAL);

      if (!shouldRefresh) return;

      const countries = getAliveCountries(); // 只顯示活國家（active, vassal, exile），過濾掉 defeated
      gameState.rankingCache = countries.map(c => ({
        name: c.name,
        power: calculateNationalPower(c),
      })).sort((a, b) => b.power - a.power);
      gameState.rankingLastUpdatedTurn = gameState.turn;
      evaluateWorldHegemony(gameState.rankingCache);

      const ranking = gameState.rankingCache || [];
      
      // 儲存之前的排名以計算趨勢
      const prevRanking = gameState.previousRanking || {};
      gameState.previousRanking = {};
      ranking.forEach((item, idx) => {
        gameState.previousRanking[item.name] = idx + 1;
      });
      
      const rankingContainer = document.getElementById('worldRankingList');
      if (!rankingContainer) return;
      rankingContainer.innerHTML = '';
      const topRanking = ranking.slice(0, 10);
      if (!topRanking.length) {
        const placeholder = document.createElement('div');
        placeholder.style.textAlign = 'center';
        placeholder.style.padding = '20px';
        placeholder.style.color = 'var(--muted)';
        placeholder.textContent = '排行榜更新中...';
        rankingContainer.appendChild(placeholder);
        return;
      }

      topRanking.forEach((item, idx) => {
        const prevRank = prevRanking[item.name] || (idx + 1);
        let trend = '＝';
        let trendColor = '';

        if (idx + 1 < prevRank) {
          trend = `↑ +${prevRank - (idx + 1)}`;
          trendColor = '#27ae60';
        } else if (idx + 1 > prevRank) {
          trend = `↓ -${(idx + 1) - prevRank}`;
          trendColor = '#e74c3c';
        }

        const row = document.createElement('div');
        row.style.display = 'grid';
        row.style.gridTemplateColumns = '1fr 1fr 1fr 1fr';
        row.style.gap = '10px';
        row.style.padding = '8px';
        row.style.borderBottom = '1px solid var(--border)';

        const rankCol = document.createElement('div');
        const rankStrong = document.createElement('strong');
        rankStrong.textContent = `${idx + 1}`;
        rankCol.appendChild(rankStrong);

        const nameCol = document.createElement('div');
        const nameStrong = document.createElement('strong');
        nameStrong.textContent = item.name;
        nameCol.appendChild(nameStrong);

        const powerCol = document.createElement('div');
        powerCol.textContent = `${item.power}`;

        const trendCol = document.createElement('div');
        trendCol.textContent = trend;
        if (trendColor) {
          trendCol.style.color = trendColor;
        }

        row.appendChild(rankCol);
        row.appendChild(nameCol);
        row.appendChild(powerCol);
        row.appendChild(trendCol);
        rankingContainer.appendChild(row);
      });
    }
    
