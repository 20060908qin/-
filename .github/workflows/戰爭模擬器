    const ENABLE_MODULAR_RUNTIME = false;
    const MAX_ACTIVE_COUNTRIES = 42;
    const MAX_ACTIONS_PER_TURN = 240;
    const ACTION_CAP_MULTIPLIER = 4;
    // ===== 前端世界地圖模型 =====
    const MAP_WIDTH = 12;
    const MAP_HEIGHT = 12;
    let WORLD_MAP = [];
    let MAP_CELL_ELEMENTS = [];

    function updateMapCells(cells) {
      if (!cells || !cells.length) return;
      cells.forEach(cell => {
        if (!cell) return;
        updateMapCellElement(cell);
      });
    }

    // 取得某國目前擁有的地格
    function getCellsOfCountry(name) {
      return [].concat(...WORLD_MAP).filter(c => c.owner === name);
    }

    // 隨機生成領袖姓名（姓 + 名 + 稱號）
    function generateLeaderName() {
      const surnames = ['蒼','玄','白','風','夜','赤','炎','月','星','金','林','蕭','韓','沈','趙','葉','蘇','秦','魏','陸','柳','子','顏','紀','顧','董','辛','馮','龔','袁','霍','沈','陶','方','蔡','潘','高','鄭','段','余','馬','韓','周','吳','張','劉','陳','許','莊','郝','侯','凌','夏','凌'];
      const given = ['子昂','承澤','景行','天曜','文軒','逸風','浩然','清河','君臨','懷瑾','若水','凌霄','靖安','遠山','長歌','思遠','羽澤','長風','瑞安','景澤','仲謀','千里','若塵','聿修','孤風','宣朗','博文','紹庭','安邦','兆堯','和璧','聖哲','仁傑','景行','逸云','景天','康平','志遠','英傑','弘文','錦程','承運','偉誠','文康','昭明','景輝','靖宇','曜光','煒宸','天佑','聖恩','安歌'];
      const titles = ['大帝','攝政王','護國公','執政官','首相','議長','總統','統帥'];
      const s = surnames[Math.floor(Math.random()*surnames.length)];
      const g = given[Math.floor(Math.random()*given.length)];
      const t = titles[Math.floor(Math.random()*titles.length)];
      return `${s}${g} ${t}`;
    }
    // 產生不含稱號的個人姓名（姓+名）
    function generatePersonalName() {
      const surnames = ['蒼','玄','白','風','夜','赤','炎','月','星','金','林','蕭','韓','沈','趙','葉','蘇','秦','魏','陸','柳','子','顏','紀','顧','董','辛','馮','龔','袁','霍','沈','陶','方','蔡','潘','高','鄭','段','余','馬','韓','周','吳','張','劉','陳','許','莊','郝','侯','凌','夏','凌'];
      const given = ['子昂','承澤','景行','天曜','文軒','逸風','浩然','清河','君臨','懷瑾','若水','凌霄','靖安','遠山','長歌','思遠','羽澤','長風','瑞安','景澤','仲謀','千里','若塵','聿修','孤風','宣朗','博文','紹庭','安邦','兆堯','和璧','聖哲','仁傑','景行','逸云','景天','康平','志遠','英傑','弘文','錦程','承運','偉誠','文康','昭明','景輝','靖宇','曜光','煒宸','天佑'];
      return surnames[Math.floor(Math.random()*surnames.length)] + given[Math.floor(Math.random()*given.length)];
    }

    function extractClanName(fullName) {
      if (!fullName || typeof fullName !== 'string') return '無名';
      return fullName.charAt(0);
    }

    function generateDynastyName(country, leaderName) {
      const clan = extractClanName(leaderName);
      const gov = country?.gov || '聯邦';
      if (gov === '帝國' || gov === '君主立憲' || gov === '軍政府') return `${clan}氏王朝`;
      if (gov === '共和國') return `${clan}氏共和派`;
      if (gov === '聯邦') return `${clan}氏財閥`;
      return `${clan}氏家系`;
    }

    function getWarCoalitionKey(countryA, countryB) {
      return [countryA, countryB].sort().join('||');
    }

    function clearWarCoalition(countryA, countryB) {
      if (!gameState.warCoalitions) gameState.warCoalitions = {};
      delete gameState.warCoalitions[getWarCoalitionKey(countryA, countryB)];
    }

    function clearWarCoalitionsByCountry(countryName) {
      if (!gameState.warCoalitions) return;
      Object.keys(gameState.warCoalitions).forEach(key => {
        const coalition = gameState.warCoalitions[key];
        if (!coalition) return;
        const allMembers = [coalition.founderAttacker, coalition.founderDefender]
          .concat((coalition.attackerAllies || []).map(a => a.name))
          .concat((coalition.defenderAllies || []).map(a => a.name));
        if (allMembers.includes(countryName)) {
          delete gameState.warCoalitions[key];
        }
      });
    }

    function pickWarSupportersAtDeclaration(leaderName, enemyName, occupiedSet) {
      const leader = gameState.countryStats[leaderName];
      if (!leader) return [];

      const joined = [];
      (leader.allies || []).forEach(allyName => {
        if (occupiedSet.has(allyName)) return;
        const ally = gameState.countryStats[allyName];
        if (!ally || ally.status === 'defeated' || ally.status === 'exile') return;
        if ((ally.ceasefires || []).includes(enemyName)) return;
        if ((ally.enemies || []).includes(leaderName)) return;

        const relation = getRelation(allyName, leaderName);
        const joinChance = Math.max(0.08, Math.min(0.72, 0.22 + relation / 180));
        if (Math.random() < joinChance) {
          const commitment = 0.14 + Math.random() * 0.2;
          joined.push({ name: allyName, commitment });
          occupiedSet.add(allyName);
        }
      });
      return joined;
    }

    function declareWarAndLockCoalition(attackerName, defenderName) {
      if (!gameState.warCoalitions) gameState.warCoalitions = {};
      const attacker = gameState.countryStats[attackerName];
      const defender = gameState.countryStats[defenderName];
      if (!attacker || !defender) return null;

      if (!attacker.enemies.includes(defender.name)) attacker.enemies.push(defender.name);
      if (!defender.enemies.includes(attacker.name)) defender.enemies.push(attacker.name);
      attacker.ceasefires = attacker.ceasefires.filter(n => n !== defender.name);
      defender.ceasefires = defender.ceasefires.filter(n => n !== attacker.name);

      const key = getWarCoalitionKey(attackerName, defenderName);
      if (gameState.warCoalitions[key]) {
        return gameState.warCoalitions[key];
      }

      const occupied = new Set([attackerName, defenderName]);
      const attackerAllies = pickWarSupportersAtDeclaration(attackerName, defenderName, occupied);
      const defenderAllies = pickWarSupportersAtDeclaration(defenderName, attackerName, occupied);

      const coalition = {
        founderAttacker: attackerName,
        founderDefender: defenderName,
        attackerAllies,
        defenderAllies,
        declaredTurn: gameState.turn,
        declaredDate: formatDateLabel(),
      };
      gameState.warCoalitions[key] = coalition;
      addNews(`${attackerName} 向 ${defenderName} 宣戰，戰局正式展開。`);

      if (attackerAllies.length > 0) {
        addNews(`${attackerName} 宣戰後獲得盟友支援（攻方）：${attackerAllies.map(a => a.name).join('、')}。`);
      }
      if (defenderAllies.length > 0) {
        addNews(`${defenderName} 宣戰應對獲得盟友支援（守方）：${defenderAllies.map(a => a.name).join('、')}。`);
      }
      return coalition;
    }

    function getWarCoalitionForBattle(attackerName, defenderName) {
      if (!gameState.warCoalitions) return null;
      const coalition = gameState.warCoalitions[getWarCoalitionKey(attackerName, defenderName)];
      if (!coalition) return null;

      if (coalition.founderAttacker === attackerName && coalition.founderDefender === defenderName) {
        return {
          attackerAllies: coalition.attackerAllies || [],
          defenderAllies: coalition.defenderAllies || []
        };
      }
      return {
        attackerAllies: coalition.defenderAllies || [],
        defenderAllies: coalition.attackerAllies || []
      };
    }

    function computeLockedWarSupportPower(supporters) {
      let power = 0;
      (supporters || []).forEach(({ name, commitment }) => {
        const ally = gameState.countryStats[name];
        if (!ally || ally.status === 'defeated' || ally.status === 'exile') return;
        const ratio = Math.max(0.08, commitment || 0.15);
        const supportPower = getCombatPower(ally) * ratio;
        power += supportPower;

        // 盟友承擔持續戰場成本，避免免費援軍
        ally.war_exhaustion = Math.min(100, (ally.war_exhaustion || 0) + 1.2 + ratio * 5);
        ally.economy = Math.max(1, (ally.economy || 1) - (supportPower / 220));
        ally.soldiers = Math.max(50, Math.floor((ally.soldiers || 0) - supportPower * 0.06));
      });
      return power;
    }

    function pickSplitCellsByCultureBlocks(parentName, takeCount) {
      const owned = getCellsOfCountry(parentName);
      if (owned.length <= takeCount) return [];
      const parent = gameState.countryStats[parentName];
      const cap = parent?.capital;

      const keyOf = cell => `${cell.row},${cell.col}`;
      const ownedMap = new Map(owned.map(cell => [keyOf(cell), cell]));
      const componentSizeByKey = new Map();
      const visited = new Set();

      // 先找連通文化區塊（以領土地理連續性代表民族/地域群）
      owned.forEach(cell => {
        const startKey = keyOf(cell);
        if (visited.has(startKey)) return;
        const queue = [cell];
        const component = [];
        visited.add(startKey);

        while (queue.length > 0) {
          const cur = queue.shift();
          component.push(cur);
          getNeighbors(cur.row, cur.col).forEach(n => {
            if (!n || n.owner !== parentName) return;
            const nk = keyOf(n);
            if (visited.has(nk)) return;
            visited.add(nk);
            queue.push(n);
          });
        }
        const size = component.length;
        component.forEach(c => componentSizeByKey.set(keyOf(c), size));
      });

      const terrainPenalty = {
        mountain: 0.24,
        desert: 0.18,
        island: 0.28,
        river: 0.08,
        plain: 0.03,
      };

      const cellScore = (cell, seed = null) => {
        const neighbors = getNeighbors(cell.row, cell.col);
        const borderPressure = neighbors.filter(n => !n || n.owner !== parentName).length / 8;
        const distToCap = cap ? (Math.abs(cell.row - cap.row) + Math.abs(cell.col - cap.col)) / Math.max(6, MAP_WIDTH + MAP_HEIGHT) : 0.2;
        const componentSize = componentSizeByKey.get(keyOf(cell)) || 1;
        const minorityBias = 1 - componentSize / Math.max(1, owned.length);
        const terrainBias = terrainPenalty[cell.terrain] || 0.05;

        let cohesion = 0;
        if (seed) {
          if (seed.terrain === cell.terrain) cohesion += 0.22;
          if ((seed.resource || null) === (cell.resource || null)) cohesion += 0.08;
          if ((componentSizeByKey.get(keyOf(seed)) || 0) === componentSize) cohesion += 0.12;
        }
        return distToCap * 0.42 + borderPressure * 0.33 + minorityBias * 0.2 + terrainBias + cohesion;
      };

      const sorted = owned.slice().sort((a, b) => cellScore(b) - cellScore(a));
      const taken = [];
      const takenSet = new Set();

      while (taken.length < takeCount) {
        const candidates = sorted.filter(cell => !takenSet.has(keyOf(cell)));
        if (candidates.length === 0) break;
        const seedPool = candidates.slice(0, Math.max(1, Math.floor(candidates.length * 0.35)));
        const seed = seedPool[Math.floor(Math.random() * seedPool.length)];
        const seedKey = keyOf(seed);

        if (!takenSet.has(seedKey)) {
          taken.push(seed);
          takenSet.add(seedKey);
        }

        const frontier = [];
        const frontierSet = new Set();
        getNeighbors(seed.row, seed.col).forEach(n => {
          if (!n || n.owner !== parentName) return;
          const nk = keyOf(n);
          if (takenSet.has(nk) || frontierSet.has(nk)) return;
          frontier.push(n);
          frontierSet.add(nk);
        });

        while (taken.length < takeCount && frontier.length > 0) {
          frontier.sort((a, b) => (cellScore(b, seed) + Math.random() * 0.08) - (cellScore(a, seed) + Math.random() * 0.08));
          const next = frontier.shift();
          const nk = keyOf(next);
          if (takenSet.has(nk)) continue;
          taken.push(next);
          takenSet.add(nk);

          getNeighbors(next.row, next.col).forEach(n => {
            if (!n || n.owner !== parentName) return;
            const nextKey = keyOf(n);
            if (takenSet.has(nextKey) || frontierSet.has(nextKey)) return;
            frontier.push(n);
            frontierSet.add(nextKey);
          });
        }
      }

      return taken.slice(0, takeCount);
    }

    // 建立分裂出來的新國家
    function createNewCountryFromSplit(parentName, takeCount) {
      const parent = gameState.countryStats[parentName];
      if (!parent) return null;
      const aliveCount = getAliveCountries().length;
      if (aliveCount >= MAX_ACTIVE_COUNTRIES) return null;
      const owned = getCellsOfCountry(parentName);
      if (owned.length <= takeCount) return null;
      // 依文化區塊權重切分，避免純隨機碎裂
      const taken = pickSplitCellsByCultureBlocks(parentName, takeCount);
      if (taken.length === 0) return null;
      // 產生新國家基本資料
      const newNameBase = generatePersonalName();
      let newName = `${newNameBase}獨立國`;
      // 保證名稱唯一
      let suffix = 1;
      while (countries.find(c=>c.name===newName) || gameState.countryStats[newName]) {
        newName = `${newNameBase}獨立國${suffix++}`;
      }
      const leaderFull = generateLeaderName();
      const leaderParts = leaderFull.split(' ');
      const newCountry = {
        name: newName,
        specialty: parent.specialty,
        personality: parent.personality,
        gov: '共和國',
        population: Math.max(5, Math.floor(parent.population * (takeCount / Math.max(1, parent.territory)))),
        economy: Math.max(1, Math.floor(parent.economy * 0.5)),
        territory: takeCount,
        cities: Math.max(1, Math.floor(parent.cities * 0.3)),
        soldiers: Math.max(5, Math.floor(parent.soldiers * 0.3)),
        elite_soldiers: Math.max(0, Math.floor(parent.elite_soldiers * 0.2)),
        terrain: parent.terrain,
        strategyDescription: '新獨立國，政局未定',
        long_term_goal: ['復仇', '獨立維持', '世界霸權', '經濟繁榮', '文化復興'][Math.floor(Math.random() * 5)],
        status: 'active',
        culture: parent.culture || '中立主義',
        culturalSphere: parent.culturalSphere || inferCulturalSphereByTerrain(parent.terrain),
        ethnicity: parent.ethnicity || ETHNIC_GROUPS[Math.floor(Math.random() * ETHNIC_GROUPS.length)],
        religion: parent.religion || RELIGIONS[Math.floor(Math.random() * RELIGIONS.length)],
        culturalIntegration: 40,
        strategy: 'defensive',
        war_exhaustion: 10,
        corruption: Math.min(100, Math.max(0, (parent.corruption || 20) + 5)),
        satisfaction: Math.min(100, Math.max(20, (parent.satisfaction || 60) - 10 + 15)),  // +15 獨立熱潮
        stability: Math.min(100, Math.max(20, (parent.stability || 60) - 20 + 20)),  // +20 獨立熱潮加成
        researched_techs: [],
        research_progress: {},
        relations: {},
        allies: [],
        enemies: [],
        ceasefires: [],
        tributaries: [],
        memory: {},
        territoryGrid: [],
        exile_months: 0,
        exile_supporter: null,
        restoration_progress: 0,
        founding_turn: gameState.turn,
        independent_defense_until: gameState.turn + 60,  // 5年（60月）防禦加成
        leader: { name: leaderParts[0], title: leaderParts[1] || '領袖', personality: parent.leader.personality, ability: Math.max(40, Math.floor(parent.leader.ability*0.6)), prestige: Math.max(20, Math.floor(parent.leader.prestige*0.5)) },
        dynasty: ''
      };
      newCountry.dynasty = generateDynastyName(newCountry, newCountry.leader.name);
      // 將這些格子歸屬給新國
      taken.forEach(cell => { cell.owner = newName; cell.isCapital = false; });
      // 調整母國戰力與城市規模
      parent.population = Math.max(1, Math.floor(parent.population * 0.75));
      parent.economy = Math.max(1, Math.floor(parent.economy * 0.8));
      parent.cities = Math.max(1, Math.floor(parent.cities * 0.8));
      parent.soldiers = Math.max(1, Math.floor(parent.soldiers * 0.7));
      parent.elite_soldiers = Math.max(0, Math.floor(parent.elite_soldiers * 0.7));
      parent.stability = Math.max(10, parent.stability - 15);
      parent.territory = getCellsOfCountry(parentName).length;
      // 註冊新國資料於 gameState
      gameState.countryStats[newName] = JSON.parse(JSON.stringify(newCountry));
      const newState = gameState.countryStats[newName];
      newState.territoryGrid = taken.map(cell => ({ row: cell.row, col: cell.col }));
      const terrainCounter = {};
      taken.forEach(cell => {
        terrainCounter[cell.terrain] = (terrainCounter[cell.terrain] || 0) + 1;
      });
      const splitMainTerrain = Object.keys(terrainCounter).sort((a, b) => terrainCounter[b] - terrainCounter[a])[0] || parent.terrain;
      newState.terrain = splitMainTerrain;
      newState.culturalSphere = inferCulturalSphereByTerrain(splitMainTerrain);
      if (Math.random() < 0.35) {
        newState.ethnicity = ETHNIC_GROUPS[Math.floor(Math.random() * ETHNIC_GROUPS.length)];
      }
      if (Math.random() < 0.25) {
        newState.religion = RELIGIONS[Math.floor(Math.random() * RELIGIONS.length)];
      }
      ensureIdentityProfile(newState);
      newState.research_progress = {};
      Object.keys(TECHS).forEach(t => { newState.research_progress[t] = 0; });
      getAllCountries().forEach(other => {
        if (!other || other.name === newName) return;
        ensureRelationsMap(other);
        ensureRelationsMap(newState).set(other.name, 50 + Math.floor(Math.random() * 11) - 5);
        ensureRelationsMap(other).set(newName, 50);
      });
      // 記錄新國誕生
      recordCountryBirth(newName, gameState.year, gameState.month, { from: parentName });
      // 新國可能會在首都附近設置首都（選第一個）
      const cap = taken[0];
      gameState.countryStats[newName].capital = { row: cap.row, col: cap.col };
      invalidateSupplyCache([parentName, newName]);
      addNews(`${formatDateLabel()}：${newName} 從 ${parentName} 宣告獨立！`);
      return newName;
    }

    // 政體演化檢查與執行
    function checkGovernmentEvolution(state) {
      if (!state || !state.gov) return;
      // 帝國可能逐漸向君主立憲或聯邦演變（若穩定且經濟好）
      if (state.gov === '帝國' && state.stability >= 60 && state.economy >= 12 && Math.random() < 0.03) {
        const next = Math.random() < 0.5 ? '君主立憲' : '聯邦';
        const oldGov = state.gov;
        state.gov = next;
        addNews(`${state.name} 的政體演化為 ${next}。`);
        handleDynastyChange(state, oldGov, next);
        return;
      }
      // 共和國在不穩定時可能走向獨裁
      if (state.gov === '共和國' && state.stability < 40 && Math.random() < 0.04) {
        const oldGov = state.gov;
        state.gov = '獨裁政權';
        addNews(`${state.name} 發生政變，政體變為 獨裁政權。`);
        handleDynastyChange(state, oldGov, '獨裁政權');
        return;
      }
      // 聯邦在極度不穩定時可能被軍方接管
      if (state.gov === '聯邦' && state.stability < 35 && Math.random() < 0.03) {
        const oldGov = state.gov;
        state.gov = '軍政府';
        addNews(`${state.name} 發生軍事政變，聯邦體制終結，軍政府上台。`);
        handleDynastyChange(state, oldGov, '軍政府');
        return;
      }
    }

    // 記錄國家誕生
    function recordCountryBirth(name, year, month, meta = {}) {
      gameState.history = gameState.history || { births: {}, deaths: [], wars: [] };
      gameState.history.births[name] = { name, year, month, meta };
    }

    // 歸檔滅亡國家 - 保存快照後刪除實時資料，防止記憶體爆炸
    function archiveCountry(countryName) {
      const state = gameState.countryStats[countryName];
      if (!state) return;
      
      // 初始化歸檔容器
      gameState.countryArchive = gameState.countryArchive || [];
      
      // 建立快照（只保留必要資訊，不保留實時資料）
      const snapshot = {
        name: state.name,
        year: gameState.year,
        month: gameState.month,
        territory: state.territory,
        population: state.population,
        economy: state.economy,
        government: state.gov,
        culture: state.culture,
        status: state.status,
        vassalOf: state.suzerain,
        exileHost: state.exile_supporter,
        finalLeader: state.leader ? { name: state.leader.name, title: state.leader.title } : null,
        finalTechs: state.researched_techs ? state.researched_techs.length : 0,
        birthYear: gameState.history?.births?.[state.name]?.year,
        deathType: gameState.history?.deaths?.find(d => d.name === state.name)?.type
      };
      
      // 儲存快照與歷史紀錄（限制歷史列表大小以節省記憶體）
      gameState.countryArchive.push(snapshot);
      if (gameState.countryArchive.length > 3000) {
        gameState.countryArchive.shift();
      }
      gameState.historicalCountries = gameState.historicalCountries || [];
      gameState.historicalCountries.push(snapshot);
      if (gameState.historicalCountries.length > 500) gameState.historicalCountries.shift();

      // 標記為已滅亡但保留完整資料，便於歷史面板、編年史與排行榜顯示
      state.status = 'defeated';
      state.defeatedYear = gameState.year;
      state.defeatedMonth = gameState.month;

      // 清理其他國家中對該國的直接引用（relations、盟友/敵人列表等），但不刪除該國本體
      Object.values(gameState.countryStats).forEach(other => {
        if (!other) return;
        if (other.relations instanceof Map) other.relations.delete(countryName);
        else if (other.relations) delete other.relations[countryName];
        if (other.allies) other.allies = other.allies.filter(a => a !== countryName);
        if (other.enemies) other.enemies = other.enemies.filter(e => e !== countryName);
        if (other.ceasefires) other.ceasefires = other.ceasefires.filter(c => c !== countryName);
        if (other.tributaries) other.tributaries = other.tributaries.filter(t => t !== countryName);
        if (other.suzerain === countryName) other.suzerain = null;
        if (other.exile_supporter === countryName) other.exile_supporter = null;
      });

      clearWarCoalitionsByCountry(countryName);
    }

    // 記錄國家滅亡或被併入等事件
    function recordCountryDeath(name, type, by, year = gameState.year, month = gameState.month, details = {}) {
      gameState.history = gameState.history || { births: {}, deaths: [], wars: [] };
      gameState.history.deaths.push({ name, type, by, year, month, details });
    }

    function recordWarHistory(attacker, defender, casualties) {
      gameState.history = gameState.history || { births: {}, deaths: [], wars: [] };
      gameState.history.warStats = gameState.history.warStats || {
        totalWars: 0,
        totalCasualties: 0,
        biggestWar: null,
        byCountry: {},
      };

      const warName = `${attacker} vs ${defender} ${formatDateLabel()}`;
      const record = { name: warName, casualties, attacker, defender, turn: gameState.turn };

      gameState.history.wars.push(record);
      if (gameState.history.wars.length > 2000) {
        gameState.history.wars.shift();
      }

      const stats = gameState.history.warStats;
      stats.totalWars += 1;
      stats.totalCasualties += casualties;
      stats.byCountry[attacker] = (stats.byCountry[attacker] || 0) + 1;
      stats.byCountry[defender] = (stats.byCountry[defender] || 0) + 1;
      if (!stats.biggestWar || casualties > stats.biggestWar.casualties) {
        stats.biggestWar = record;
      }
    }

    // 處理王朝/政權更替並在必要時改名
    function handleDynastyChange(state, oldGov, newGov) {
      if (!state || !state.name) return;
      const orig = state.name;
      let newName = orig;
      // 簡單的命名策略：政體後綴改寫或加入「朝/國/共和國」等
      if (oldGov === '帝國' && (newGov === '君主立憲' || newGov === '聯邦')) {
        if (!orig.includes('王朝') && Math.random() < 0.6) newName = orig.replace(/帝國$/,'王朝');
        else if (!orig.includes('聯邦') && newGov === '聯邦') newName = orig.replace(/帝國$/,'聯邦');
      }
      if (oldGov === '共和國' && newGov === '獨裁政權') {
        if (!orig.includes('政權')) newName = orig + '政權';
      }
      if (newGov === '軍政府') {
        if (!orig.includes('軍')) newName = orig + '（軍政府）';
      }
      if (newName !== orig) {
        renameCountry(orig, newName);
        addChronicle(`${formatDateLabel()}：${orig} 更名為 ${newName}（政體由 ${oldGov} 轉為 ${newGov}）。`);
      }
    }

    // 將國家改名，更新各處參考
    function renameCountry(oldName, newName) {
      // 更新 gameState.countryStats
      const state = gameState.countryStats[oldName];
      if (!state) return;
      state.name = newName;
      gameState.countryStats[newName] = state;
      delete gameState.countryStats[oldName];
      if (gameState.selectedCountry === oldName) gameState.selectedCountry = newName;
      
      // 更新 WORLD_MAP 佔有者
      [].concat(...WORLD_MAP).forEach(cell => { if (cell.owner === oldName) cell.owner = newName; });
      
      // 更新 gameState.defeatedCountries 與其他資料
      gameState.defeatedCountries = gameState.defeatedCountries.map(n => n === oldName ? newName : n);
      
      // 更新 countries 關聯名稱（relations、allies、enemies）
      getAllCountries().forEach(s => {
        const relMap = ensureRelationsMap(s);
        if (relMap.has(oldName)) {
          relMap.set(newName, relMap.get(oldName));
          relMap.delete(oldName);
        }
        if (s.allies) s.allies = s.allies.map(a => a === oldName ? newName : a);
        if (s.enemies) s.enemies = s.enemies.map(e => e === oldName ? newName : e);
      });
      
      // 更新 battleReports 中的簡單提及
      gameState.battleReports.forEach(r => { 
        if (r.attacker === oldName) r.attacker = newName; 
        if (r.defender === oldName) r.defender = newName; 
        if (r.winner === oldName) r.winner = newName; 
        if (r.loser === oldName) r.loser = newName; 
      });
      
      // 更新歷史記錄中的國家名稱
      if (gameState.history) {
        // 更新誕生記錄
        if (gameState.history.births && gameState.history.births[oldName]) {
          gameState.history.births[newName] = gameState.history.births[oldName];
          gameState.history.births[newName].name = newName;
          delete gameState.history.births[oldName];
        }
        
        // 更新滅亡記錄
        if (gameState.history.deaths) {
          gameState.history.deaths.forEach(d => {
            if (d.name === oldName) d.name = newName;
            if (d.by === oldName) d.by = newName;
          });
        }
        
        // 更新戰爭記錄
        if (gameState.history.wars) {
          gameState.history.wars.forEach(w => {
            // 戰爭名稱中的國家名稱更新
            if (w.name) {
              w.name = w.name.replace(new RegExp(oldName, 'g'), newName);
            }
            if (w.attacker === oldName) w.attacker = newName;
            if (w.defender === oldName) w.defender = newName;
          });
        }
        if (gameState.history.warStats && gameState.history.warStats.byCountry) {
          const byCountry = gameState.history.warStats.byCountry;
          if (byCountry[oldName] !== undefined) {
            byCountry[newName] = (byCountry[newName] || 0) + byCountry[oldName];
            delete byCountry[oldName];
          }
          const biggestWar = gameState.history.warStats.biggestWar;
          if (biggestWar) {
            if (biggestWar.attacker === oldName) biggestWar.attacker = newName;
            if (biggestWar.defender === oldName) biggestWar.defender = newName;
            if (biggestWar.name) biggestWar.name = biggestWar.name.replace(new RegExp(oldName, 'g'), newName);
          }
        }
      }
      
      // 更新宗主國/流亡支持者參考
      getAllCountries().forEach(s => {
        if (s.suzerain === oldName) s.suzerain = newName;
        if (s.exile_supporter === oldName) s.exile_supporter = newName;
      });
      
      // 更新勝利紀錄（如果存在）
      if (gameState.victories && gameState.victories[oldName]) {
        gameState.victories[newName] = gameState.victories[oldName];
        delete gameState.victories[oldName];
      }
      if (gameState.victoryCounters && gameState.victoryCounters[oldName]) {
        gameState.victoryCounters[newName] = gameState.victoryCounters[oldName];
        delete gameState.victoryCounters[oldName];
      }

      clearWarCoalitionsByCountry(oldName);
    }

    // 計算世界霸權排名（依影響力）
    function computeWorldRanking() {
      try {
        if (ENABLE_MODULAR_RUNTIME && typeof computeWorldRankingModular === 'function' && window.moduleSystem?.isInitialized) {
          const modularRanks = computeWorldRankingModular();
          if (Array.isArray(modularRanks) && modularRanks.length > 0) {
            return modularRanks.map(r => ({
              name: r.name,
              score: Number.isFinite(r.score) ? r.score : (Number.isFinite(r.power) ? r.power : 0),
              power: Number.isFinite(r.power) ? r.power : (Number.isFinite(r.score) ? r.score : 0),
            }));
          }
        }
      } catch (e) {
        console.warn('模組化排名計算失敗，回退預設計算。', e);
      }

      const alive = getAliveCountries();
      const ranks = alive.map(c => ({ name: c.name, score: calculateInfluence(gameState.countryStats[c.name]) }));
      ranks.sort((a,b) => b.score - a.score);
      return ranks;
    }

    // 生成終局總結（在模擬結束時呼叫）
    function generateFinalSummary() {
      const ranks = computeWorldRanking();
      const top = ranks.slice(0,5).map((r,i)=>`${i+1}. ${r.name} (${Math.round(r.score)})`).join('\n');
      
      // 最長存續國家
      const lifetimes = Object.keys(gameState.history.births).map(name => {
        const birth = gameState.history.births[name];
        const death = gameState.history.deaths.find(d => d.name === name);
        const endYear = death ? (death.year + (death.month/12)) : (gameState.year + (gameState.month/12));
        const start = birth.year + (birth.month/12);
        return { name, years: Math.max(0, endYear - start) };
      });
      lifetimes.sort((a,b)=>b.years-a.years);
      const longest = lifetimes[0] ? `${lifetimes[0].name}（持續 ${lifetimes[0].years.toFixed(1)} 年）` : '—';
      
      // 最強帝國（最大領土）
      const aliveAll = getAllCountries();
      const maxTerr = aliveAll.reduce((mx, s) => s.territory > (mx.territory||0) ? s : mx, {});
      const strongest = maxTerr && maxTerr.name ? `${maxTerr.name}（${maxTerr.territory} 格）` : '—';
      
      const warStats = gameState.history.warStats || { totalWars: 0, biggestWar: null, byCountry: {} };
      // 最大戰爭（使用聚合統計，避免掃描全部歷史）
      const biggestWar = warStats.biggestWar;
      const biggest = biggestWar ? `${biggestWar.name}（死亡 ${biggestWar.casualties}）` : '—';
      
      // 勝利統計
      const victories = Object.entries(gameState.victories || {}).map(([name, type]) => `${name}（${type}）`).join('；');
      const victoryLine = victories ? `勝利者：${victories}` : '尚無勝利者';
      
      // 最多戰爭的國家
      const warCounts = warStats.byCountry || {};
      const mostWarsCountry = Object.entries(warCounts).sort((a,b) => b[1] - a[1])[0];
      const mostWars = mostWarsCountry ? `${mostWarsCountry[0]}（${mostWarsCountry[1]}場戰爭）` : '—';
      
      // 最多技術
      const techCounts = aliveAll.map(c => ({ name: c.name, techs: (c.researched_techs?.length || 0) }));
      techCounts.sort((a,b) => b.techs - a.techs);
      const mostTech = techCounts[0] && techCounts[0].techs > 0 ? `${techCounts[0].name}（${techCounts[0].techs}項技術）` : '—';
      
      // 最大聯盟
      const allianceCounts = aliveAll.map(c => ({ name: c.name, allies: (c.allies?.length || 0) }));
      allianceCounts.sort((a,b) => b.allies - a.allies);
      const largestAlliance = allianceCounts[0] && allianceCounts[0].allies > 0 ? `${allianceCounts[0].name}（${allianceCounts[0].allies}個盟友）` : '—';
      
      // 國家統計
      const totalCountries = Object.keys(gameState.history.births).length;
      const defeatedCountries = (gameState.history.deaths || []).length;
      const aliveCountries = totalCountries - defeatedCountries;
      
      const summary = `世界歷史總結（${gameState.year}年${gameState.month}月）

=== 世界排名 ===
${top}

=== 主要成就 ===
${victoryLine}
最長存續：${longest}
領土最大：${strongest}
戰爭最多：${mostWars}
技術最先進：${mostTech}
聯盟最大：${largestAlliance}
最慘烈戰爭：${biggest}

=== 統計數據 ===
共誕生國家：${totalCountries}個
現存國家：${aliveCountries}個
滅亡國家：${defeatedCountries}個
總戰爭數：${warStats.totalWars || 0}場`;
      
      addChronicle(`終局總結：\n${summary}`);
      addNews('模擬已結束，已產生終局總結。');
      console.log('終局總結已生成：', summary);
    }
    function formatDateLabel(year = gameState.year, month = gameState.month) {
      return `${year}年${month}月`;
    }

    function advanceMonth() {
      gameState.month += 1;
      if (gameState.month > 12) {
        gameState.month = 1;
        gameState.year += 1;
      }
    }

    function createWorldMap(width = MAP_WIDTH, height = MAP_HEIGHT) {
      WORLD_MAP = [];
      for (let r = 0; r < height; r++) {
        const row = [];
        for (let c = 0; c < width; c++) {
          row.push({ owner: null, terrain: 'plain', city: false, resource: null, isCapital: false, row: r, col: c });
        }
        WORLD_MAP.push(row);
      }
    }

    function assignRegionsToMap() {
      // 類似後端分配：隨機為每國分配連續區塊，並設定首都
      const flat = [].concat(...WORLD_MAP);
      let unassigned = flat.slice();
      const order = getCountriesByStatus(['active', 'vassal', 'defeated']);
      // 計算每國想要的格數（基於 territory 比例）
      const totalTerr = order.reduce((s,c)=>s+Math.max(1,c.territory||1),0);
      const sizes = order.map(c => Math.max(2, Math.round((c.territory||10)/totalTerr * flat.length)));
      // adjust sum
      let sum = sizes.reduce((a,b)=>a+b,0);
      while (sum > flat.length) { sizes[sizes.indexOf(Math.max(...sizes))]--; sum--; }
      while (sum < flat.length) { sizes[sizes.indexOf(Math.min(...sizes))]++; sum++; }

      // 分配
      order.forEach((country, idx) => {
        let size = sizes[idx];
        if (unassigned.length === 0) return;
        const seedIndex = Math.floor(Math.random()*unassigned.length);
        const seed = unassigned.splice(seedIndex,1)[0];
        seed.owner = country.name;
        seed.isCapital = true;
        seed.terrain = Math.random()<0.1 ? 'port' : 'plain';
        country.capital = {row: seed.row, col: seed.col};
        country.cities = country.cities || 1;
        const assigned = [seed];
        for (let i=1;i<size;i++){
          // 找到相鄰的未分配格子優先擴展
          const adj = [];
          assigned.forEach(a=>{
            getNeighbors(a.row,a.col).forEach(n=>{ if (!n.owner) adj.push(n); });
          });
          let pick = null;
          if (adj.length>0) pick = adj[Math.floor(Math.random()*adj.length)];
          else if (unassigned.length>0) pick = unassigned[Math.floor(Math.random()*unassigned.length)];
          if (!pick) break;
          pick.owner = country.name;
          pick.terrain = Math.random()<0.12 ? 'mountain' : Math.random()<0.08 ? 'resource' : 'plain';
          if (pick.terrain==='resource') pick.resource = ['iron','oil','food','gold','rare earth'][Math.floor(Math.random()*5)];
          // remove from unassigned
          unassigned = unassigned.filter(u => !(u.row===pick.row && u.col===pick.col));
          assigned.push(pick);
        }
        // 記錄格子到國家資料
        country.territoryGrid = assigned.map(c=>({row:c.row,col:c.col}));
      });
      // 剩餘中立格子設定地形
      unassigned.forEach(cell=>{ cell.terrain = Math.random()<0.2?'sea':Math.random()<0.15?'desert':'plain'; if (cell.terrain==='sea' && Math.random()<0.12) cell.resource='oil'; });
    }

    function getNeighbors(r,c){
      const d = [[-1,0],[1,0],[0,-1],[0,1]];
      const out = [];
      d.forEach(([dr,dc])=>{ const nr=r+dr,nc=c+dc; if(nr>=0&&nr<MAP_HEIGHT&&nc>=0&&nc<MAP_WIDTH) out.push(WORLD_MAP[nr][nc]); });
      return out;
    }

    function createMapGridSkeleton() {
      const container = document.getElementById('mapGrid');
      if (!container) return;

      container.innerHTML = '';
      MAP_CELL_ELEMENTS = [];

      WORLD_MAP.forEach(row => {
        const domRow = [];
        row.forEach(cell => {
          const el = document.createElement('div');
          el.className = 'map-cell';
          el.dataset.r = cell.row;
          el.dataset.c = cell.col;
          el.addEventListener('click', () => showMapCellInfo(cell));
          container.appendChild(el);
          domRow.push(el);
        });
        MAP_CELL_ELEMENTS.push(domRow);
      });
    }

    function updateMapCellElement(cell) {
      const el = MAP_CELL_ELEMENTS[cell.row] && MAP_CELL_ELEMENTS[cell.row][cell.col];
      if (!el) return;

      el.className = 'map-cell terrain-' + (cell.terrain || 'plain');
      el.title = `${cell.row},${cell.col} ${cell.terrain} ${cell.owner ? (' / ' + cell.owner) : ''} ${cell.resource ? ('/' + cell.resource) : ''}`;
      el.innerHTML = cell.isCapital ? '★' : (cell.resource ? '?' : (cell.terrain === 'sea' ? '~' : ''));

      if (cell.owner) {
        const badge = document.createElement('div');
        badge.className = 'owner-badge';
        badge.textContent = cell.owner.substring(0, 2);
        el.appendChild(badge);
      }
    }

    function renderMapGrid(){
      const container = document.getElementById('mapGrid');
      if(!container) return;

      if (!MAP_CELL_ELEMENTS.length || MAP_CELL_ELEMENTS.length !== WORLD_MAP.length) {
        createMapGridSkeleton();
      }

      try {
        if (ENABLE_MODULAR_RUNTIME && typeof updateMapGridModular === 'function' && window.moduleSystem?.isInitialized) {
          updateMapGridModular([].concat(...WORLD_MAP));
          return;
        }
      } catch (e) {
        console.warn('模組化地圖更新失敗，回退預設渲染。', e);
      }

      WORLD_MAP.forEach(row => {
        row.forEach(cell => {
          updateMapCellElement(cell);
        });
      });
    }

    function showMapCellInfo(cell) {
      const info = [];
      info.push(`位置: ${cell.row},${cell.col}`);
      info.push(`地形: ${cell.terrain}`);
      if (cell.resource) info.push(`資源: ${cell.resource}`);
      if (cell.owner) info.push(`所有者: ${cell.owner}`);
      if (cell.isCapital) info.push('首都');
      const panel = document.getElementById('mapInfo');
      if (!panel) return;
      panel.innerHTML = '';
      const title = document.createElement('strong');
      title.textContent = '地圖格資訊';
