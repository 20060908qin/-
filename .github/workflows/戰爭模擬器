    <script>
      (function setupPanelGuardBootstrap() {
        window.__warPanelGuard = window.__warPanelGuard || {
          installed: false,
          observer: null,
        };

        window.cleanOrphanPanels = function cleanOrphanPanels() {
          try {
            const main = document.getElementById('main-container');
            if (!main) return;

            document.querySelectorAll('section.panel').forEach(panel => {
              if (!main.contains(panel)) panel.remove();
            });

            const dedupeIds = ['chroniclePanel', 'battleReports', 'nextTurnBtn', 'autoRunBtn', 'resetBtn', 'newsTabBtn', 'historyTabBtn'];
            dedupeIds.forEach(id => {
              const els = Array.from(document.querySelectorAll('#' + id));
              if (els.length <= 1) return;
              let keep = els.findIndex(el => main.contains(el));
              if (keep < 0) keep = 0;
              els.forEach((el, i) => {
                if (i !== keep) {
                  const hostPanel = el.closest('section.panel');
                  if (hostPanel && !main.contains(hostPanel)) hostPanel.remove();
                  else el.remove();
                }
              });
            });
          } catch (e) {
            console.warn('cleanOrphanPanels error', e);
          }
        };

        window.ensurePanelGuard = function ensurePanelGuard() {
          const guard = window.__warPanelGuard;
          if (guard.installed) return;

          const main = document.getElementById('main-container');
          if (!main) {
            document.addEventListener('DOMContentLoaded', () => {
              guard.installed = false;
              window.ensurePanelGuard();
            }, { once: true });
            return;
          }

          guard.installed = true;
          window.cleanOrphanPanels();

          guard.observer = new MutationObserver(() => {
            window.cleanOrphanPanels();
          });

          guard.observer.observe(main, { childList: true, subtree: true });
        };
      })();
    </script>
