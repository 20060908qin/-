    // A級：非戰爭國家建設機制
    function executeNationBuilding(countryName, type) {
      const country = gameState.countryStats[countryName];
      if (!country) return;
      
      let message = '';
      switch(type) {
        case 'economy':
          const economyBoost = Math.ceil(country.economy * 0.15);
          country.economy += economyBoost;
          country.satisfaction = Math.max(0, country.satisfaction - 10);
          message = `${countryName} 進行經濟建設，經濟增加 ${economyBoost}B，但民心下降 10 點。`;
          break;
        case 'population':
          const popBoost = Math.ceil(country.population * 0.08);
          country.population += popBoost;
          country.stability = Math.max(0, country.stability - 5);
          message = `${countryName} 實行人口移民政策，人口增加 ${popBoost}M，穩定性下降 5 點。`;
          break;
        case 'culture':
          country.satisfaction = Math.min(100, country.satisfaction + 15);
          message = `${countryName} 進行文化發展，民心增加 15 點，國民快樂指數上升。`;
          break;
        case 'infrastructure':
          const cityBoost = Math.max(1, Math.ceil(country.cities * 0.2));
          const economyNeeded = Math.ceil(country.economy * 0.1);
          if (country.economy >= economyNeeded) {
            country.cities += cityBoost;
            country.economy -= economyNeeded;
            message = `${countryName} 進行基礎建設，增加 ${cityBoost} 座城市，經濟消耗 ${economyNeeded}B。`;
          } else {
            message = `${countryName} 基礎建設因經濟不足而延期（需要 ${economyNeeded}B，當前 ${country.economy}B）。`;
          }
          break;
      }
      
      addNews(message);
      renderDetailView();
      updateStats();
    }

    // === 世界奇觀系統 ===
    function canBuildWonder(country, wonderName) {
      const wonder = WORLD_WONDERS.find(w => w.name === wonderName);
      if (!wonder) return false;
      if (country.economy < wonder.cost) return false;
      if (gameState.wonders[country.name] && gameState.wonders[country.name].find(w => w.name === wonderName)) return false;
      return true;
    }
    
    function buildWonder(countryName, wonderName) {
      const country = gameState.countryStats[countryName];
      if (!country || !canBuildWonder(country, wonderName)) return false;
      
      const wonder = WORLD_WONDERS.find(w => w.name === wonderName);
      country.economy -= wonder.cost;
      
      if (!gameState.wonders[countryName]) {
        gameState.wonders[countryName] = [];
      }
      gameState.wonders[countryName].push(wonder);
      
      addNews(`🏛️ ${countryName} 完成世界奇觀「${wonderName}」！獲得永久加成！`);
      addChronicle(`${formatDateLabel()}：${countryName} 完成${wonderName}。`);
      return true;
    }
    
    // 應用奇觀效果
    function applyWonderEffects(country) {
      if (!gameState.wonders[country.name]) return;
      
      gameState.wonders[country.name].forEach(wonder => {
        if (wonder.effects.defense) country.soldiers = Math.floor(country.soldiers * (1 + wonder.effects.defense));
        if (wonder.effects.economy) country.economy = Math.floor(country.economy * (1 + wonder.effects.economy));
        if (wonder.effects.research_speed) {
          Object.keys(country.research_progress).forEach(t => {
            country.research_progress[t] *= (1 + wonder.effects.research_speed);
          });
        }
        if (wonder.effects.naval) {
          if (country.researched_techs && country.researched_techs.includes('naval')) {
            country.soldiers = Math.floor(country.soldiers * (1 + wonder.effects.naval * 0.5));
          }
        }
        if (wonder.effects.cultural_integration) {
          country.culturalIntegration = Math.min(100, (country.culturalIntegration || 55) + wonder.effects.cultural_integration);
        }
        if (wonder.effects.stability) {
          country.stability = Math.min(100, (country.stability || 50) + wonder.effects.stability);
        }
        if (wonder.effects.satisfaction) {
          country.satisfaction = Math.min(100, (country.satisfaction || 50) + wonder.effects.satisfaction);
        }
      });
    }

