    function updateEconomy() {
      getAliveCountries().forEach(c => {
        const state = gameState.countryStats[c.name];
        state.economy = Math.max(1, state.economy + calculateEconomicIncome(state));
        const newSoldiers = calculateRecruitment(state);
        state.soldiers = Math.min(state.soldiers + newSoldiers, state.population * 2);
      });
    }

    function updatePolitics() {
      getAliveCountries().forEach(c => {
        const state = gameState.countryStats[c.name];
        state.war_exhaustion = Math.max(0, state.war_exhaustion - 2);
        state.satisfaction = Math.min(100, state.satisfaction + 1);
        state.corruption = Math.max(0, state.corruption - 1);
        state.stability = Math.min(100, state.stability + 0.5);

        if (state.war_exhaustion > 20) {
          const fatiguePenalty = state.war_exhaustion * 0.02;
          state.economy = Math.max(1, state.economy - fatiguePenalty);
          state.stability = Math.max(0, state.stability - fatiguePenalty * 0.6);
        }

        if (state.stability < 35 && Math.random() < 0.016) {
          addNews(`${state.name}爆發內亂，政府陷入危機！`);
          state.satisfaction = Math.max(0, state.satisfaction - 20);
          state.economy = Math.max(1, state.economy - 8);
          state.war_exhaustion = Math.min(100, state.war_exhaustion + 15);
        }

        triggerInternalEvent(state);
        checkLeaderDeath(state);
      });
    }

    function updateDiplomacy() {
      getAliveCountries().forEach(c => {
        const state = gameState.countryStats[c.name];
        state.allies.forEach(ally => modifyRelation(c.name, ally, 2));
        state.ceasefires = state.ceasefires.filter(other => {
          if (Math.random() < 0.004) {
            addNews(`${c.name}與${other}的停戰協議到期。`);
            return false;
          }
          return true;
        });

        getAliveCountries().forEach(other => {
          if (other.name !== c.name && !state.allies.includes(other.name) && !state.enemies.includes(other.name)) {
            const drift = getRelation(c.name, other.name) > 60 ? 1 : -0.4;
            modifyRelation(c.name, other.name, drift);
          }
        });
      });
    }

    function updateAI() {
      getAliveCountries().forEach(c => {
        const state = gameState.countryStats[c.name];
        if (!state) return;
        ensureIdentityProfile(state);

        // === 动态目标系统：每个月重新评估目标 ===
        if (Math.random() < 0.3) {  // 30% 机率每月重新评估
          state.long_term_goal = reassessLongTermGoal(state);
        }

        if (state.currentGoal && Math.random() < 0.15) {
          state.long_term_goal = state.currentGoal;
        }

        const goalType = deriveGoalArchetype(state);
        if (goalType === 'revenge') {
          state.strategy = 'vengeful';
        } else if (goalType === 'commercial') {
          state.strategy = 'economic';
        } else if (goalType === 'hegemon') {
          state.strategy = 'aggressive';
        } else if (goalType === 'suzerain') {
          state.strategy = 'diplomatic';
        } else if (goalType === 'anti_hegemon') {
          state.strategy = 'defensive';
        } else if (goalType === 'survival') {
          state.strategy = 'defensive';
        } else if (state.war_exhaustion > 35) {
          state.strategy = 'defensive';
        } else if (Object.values(state.memory || {}).some(m => m.hatred > 45)) {
          state.strategy = 'vengeful';
        } else if (state.economy > 80 && state.leader.personality === 'economic') {
          state.strategy = 'economic';
        } else if ((state.allies?.length || 0) >= 2 && state.leader.personality === 'diplomatic') {
          state.strategy = 'diplomatic';
        } else if (state.leader.personality === 'aggressive') {
          state.strategy = 'aggressive';
        }
      });
    }

    function updateWars() {
      if (!Array.isArray(gameState.turnOrder) || gameState.turnOrder.length === 0) {
        prepareTurn();
      }
      const aliveCount = Math.max(1, getAliveCountries().length);
      const actionCap = Math.max(MAX_ACTIONS_PER_TURN, aliveCount * ACTION_CAP_MULTIPLIER);
      let actions = 0;
      while (actions < actionCap && performAction()) {
        actions += 1;
      }
      if (actions >= actionCap) {
        console.warn(`戰爭行動達上限(${actionCap})，剩餘行動順延至下月。`);
      }
      checkVictory();
    }

    function generateNews() {
      triggerHistoricalEvent();
      if (gameState.turnEvents.length === 0) {
        addNews('本月未發生重大事件，世界保持平穩。');
      }
      addChronicle(`${formatDateLabel()}紀要：${gameState.turnEvents.slice(0, 4).join('； ')}`);
      gameState.turnEvents = [];
    }

    function endTurn() {
      // 月結算（統一邏輯，不重複）
      try {
        applyRoundEffects();
      } catch (e) {
        console.error('applyRoundEffects 錯誤（已容錯）', e);
      }
      
      // 戰爭決議
      try {
        updateWars();
      } catch (e) {
        console.error('updateWars 錯誤（已容錯）', e);
      }
      
      // AI決策與新聞
      try {
        updateAI();
      } catch (e) {
        console.error('updateAI 錯誤（已容錯）', e);
      }
      try {
        generateNews();
      } catch (e) {
        console.error('generateNews 錯誤（已容錯）', e);
      }
      
      gameState.turn += 1;
      advanceMonth();
      if (ENABLE_MODULAR_RUNTIME && typeof notifyTurnStart === 'function' && window.moduleSystem?.isInitialized) {
        notifyTurnStart();
      }
      updateWorldEraProgression();
      updateStats();
      updateReportPanel();
      updateNewsPanel();
      updateChroniclePanel();
      renderCountryList();
      renderDetailView();
    }

    // ========== 文化系統 ==========
    function getCultureEffect(culture) {
      const effects = {
        '軍國主義': '好戰傾向↑、領土擴張慾望↑',
        '商業至上': '經濟成長↑、和平傾向↑',
        '孤立主義': '防禦力↑、對外交往↓',
        '榮譽復仇': '復仇驅動↑、仇恨記憶↑',
        '擴張殖民': '領土掌控↑、殖民願望↑',
        '宗教狂熱': '意識形態堅持↑、對異信仰敵意↑',
        '民本主義': '民心管理↑、起義風險↓',
        '實用主義': '靈活變通↑、策略調整↑',
        '中立主義': '平衡發展',
      };
      return effects[culture] || '獨特文化';
    }

    // ========== 外交系統 ==========
    function getRelation(countryA, countryB) {
      const stateA = gameState.countryStats[countryA];
      if (!stateA) return 50;
      const stateB = gameState.countryStats[countryB];
      ensureIdentityProfile(stateA);
      if (stateB) ensureIdentityProfile(stateB);
      const base = ensureRelationsMap(stateA).get(countryB) ?? 50;
      const bonus = stateB ? getCulturalRelationBonus(stateA, stateB) : 0;
      return Math.max(0, Math.min(100, base + bonus));
    }

    function setRelation(countryA, countryB, value) {
      const stateA = gameState.countryStats[countryA];
      if (stateA) {
        ensureRelationsMap(stateA).set(countryB, Math.max(0, Math.min(100, value)));
      }
    }

    function modifyRelation(countryA, countryB, delta) {
      const newVal = getRelation(countryA, countryB) + delta;
      setRelation(countryA, countryB, newVal);
    }

    function canFormAlliance(countryA, countryB) {
      const rel = getRelation(countryA, countryB);
      const stateA = gameState.countryStats[countryA];
      const trust = stateA.memory[countryB]?.trust || 0;
      const threshold = trust > 30 ? 45 : 55;
      return rel >= threshold && !isAtWar(countryA, countryB) && !stateA.allies.includes(countryB);
    }

    function isAtWar(countryA, countryB) {
      const stateA = gameState.countryStats[countryA];
      return stateA?.enemies?.includes(countryB) ?? false;
    }

    function formAlliance(countryA, countryB) {
      const stateA = gameState.countryStats[countryA];
      const stateB = gameState.countryStats[countryB];
      if (stateA && stateB && canFormAlliance(countryA, countryB)) {
        if (!stateA.allies.includes(countryB)) stateA.allies.push(countryB);
        if (!stateB.allies.includes(countryA)) stateB.allies.push(countryA);
        modifyRelation(countryA, countryB, 15);
        modifyRelation(countryB, countryA, 15);
        recordMemory(stateA, countryB, 'alliance', 15);
        recordMemory(stateB, countryA, 'alliance', 15);
        addNews(`${countryA}與${countryB}正式結盟！`);
        return true;
      }
      return false;
    }

    function signCeasefire(countryA, countryB) {
      const stateA = gameState.countryStats[countryA];
      const stateB = gameState.countryStats[countryB];
      if (stateA && stateB) {
        setTimedCeasefire(countryA, countryB, 24 + Math.floor(Math.random() * 18));
        return true;
      }
      return false;
    }

    // ========== 經濟系統 ==========
    function calculateEconomicIncome(country) {
      const cityIncome = (country.cities || 10) * 0.3;
      const populationIncome = (country.population || 50) * 0.05;
      const militaryMaintenance = (country.soldiers || 30) * 0.02;
      let baseIncome = cityIncome + populationIncome - militaryMaintenance;
      
      // 戰爭疲勞懲罰：疲勞越高經濟產出越低
      const warExhaustionPenalty = 1 - ((country.war_exhaustion || 0) / 200);
      baseIncome *= Math.max(0.4, warExhaustionPenalty);  // 最多減少 60%
      
      // 文明特質加成
      if (country.civilizationTrait && country.civilizationTrait.bonus.economy) {
        baseIncome *= (1 + country.civilizationTrait.bonus.economy);
      }
      
      return baseIncome;
    }

    // ========== 招募系統 ==========
    function calculateRecruitment(country) {
      const baseSoldiers = (country.population || 50) * 0.0025;
      const satisfactionFactor = (country.satisfaction || 50) / 100;
      const stabilityFactor = (country.stability || 50) / 100;
      return Math.floor(baseSoldiers * satisfactionFactor * stabilityFactor);
    }

    // ========== 內政事件 ==========
    const INTERNAL_EVENTS = [
      { name: "爆發貪污醜聞", corruption: 20, satisfaction: -15, stability: -10 },
      { name: "糧食豐收", economy: 5, satisfaction: 15, population: 3 },
      { name: "經濟危機", economy: -5, satisfaction: -20, stability: -15 },
      { name: "科技突破", economy: 3, research_boost: 1 },
      { name: "民眾示威", satisfaction: -25, stability: -20, corruption: 10 },
      { name: "疫病流行", population: -5, satisfaction: -10 },
      { name: "天然災害", territory: -3, economy: -3, population: -5, stability: -10 },
      { name: "豐富礦產發現", economy: 8, population: 2 },
      { name: "文化繁榮", satisfaction: 20, stability: 10, corruption: -5 }
    ];

    function triggerInternalEvent(country) {
      if (Math.random() > 0.25) return; // 25% 機率
      const event = INTERNAL_EVENTS[Math.floor(Math.random() * INTERNAL_EVENTS.length)];
      if (!event) return;
      
      if (event.corruption) country.corruption = Math.max(0, Math.min(100, country.corruption + event.corruption));
      if (event.satisfaction) country.satisfaction = Math.max(0, Math.min(100, country.satisfaction + event.satisfaction));
      if (event.stability) country.stability = Math.max(0, Math.min(100, country.stability + event.stability));
      if (event.economy) country.economy = Math.max(1, country.economy + event.economy);
      if (event.population) country.population = Math.max(1, country.population + event.population);
      if (event.territory) country.territory = Math.max(10, country.territory + event.territory);
      if (event.research_boost) Object.keys(country.research_progress).forEach(t => { country.research_progress[t] += event.research_boost; });
      
      addNews(`${country.name}：${event.name}`);
    }

    // ========== 領袖系統 ==========
    const LEADER_TITLES = ["統帥", "總理", "民選領袖", "將軍", "財相", "總統", "元帥", "工部長", "海軍上將", "行政長官"];
    const LEADER_NAMES = [];

    function generateLeader() {
      const personalities = ["aggressive", "diplomatic", "economic", "tactical"];
      return {
        name: generatePersonalName(),
        title: LEADER_TITLES[Math.floor(Math.random() * LEADER_TITLES.length)],
        personality: personalities[Math.floor(Math.random() * personalities.length)],
        ability: Math.floor(Math.random() * 25 + 55), // 55-80
        prestige: Math.floor(Math.random() * 20 + 60), // 60-80
        monthsInPower: 0
      };
    }

    function checkLeaderDeath(country) {
      country.leader.monthsInPower = (country.leader.monthsInPower || 0) + 1;
      const years = country.leader.monthsInPower / 12;
      const deathChance = Math.min(0.1, years * 0.02); // 越老越容易死
      
      if (Math.random() < deathChance || country.leader.monthsInPower > 300) {
        const reason = Math.random() > 0.5 ? "自然死亡" : "遭暗殺";
        const oldLeader = country.leader.name;
        const oldDynasty = country.dynasty || generateDynastyName(country, oldLeader);
        let newLeader = generateLeader();
        let successionType = '同族繼承';
        const coupChance = country.stability < 35 ? 0.45 : 0.2;

        if (Math.random() < coupChance) {
          successionType = '政變奪權';
          newLeader.personality = 'aggressive';
          newLeader.ability = Math.min(100, newLeader.ability + 8);
          country.dynasty = generateDynastyName(country, newLeader.name);
        } else if (Math.random() < 0.25) {
          successionType = '王朝斷絕';
          country.dynasty = generateDynastyName(country, newLeader.name);
        } else {
          country.dynasty = oldDynasty;
        }

        newLeader.monthsInPower = 0;
        addNews(`${country.name}的統領${country.leader.name}${reason}！${newLeader.name}${newLeader.title}接任（${country.dynasty}，${successionType}）。`);
        addChronicle(`${formatDateLabel()}：${country.name}的統領${oldLeader}${reason}，${newLeader.name}繼任（${country.dynasty}，${successionType}）。`);

        if (successionType !== '同族繼承') {
          addNews(`🏛️ ${country.name} 政局巨變：${oldDynasty} 結束，${country.dynasty} 崛起。`);
        }

        country.leader = newLeader;
        country.satisfaction = Math.max(0, country.satisfaction - 15);
        country.stability = Math.max(0, country.stability - 10);
      }
    }

    // ========== 科技樹前置 ==========
    function canResearchTech(country, techId) {
      const tech = TECHS[techId];
      if (!tech || country.researched_techs.includes(techId)) return false;
      if (tech.prerequisite) {
        return tech.prerequisite.every(prereq => country.researched_techs.includes(prereq));
      }
      return true;
    }

    function calculateInfluence(country) {
      const alliesScore = (country.allies?.length || 0) * 8;
      const techScore = (country.researched_techs?.length || 0) * 6;
      return country.economy * 1.3 + country.territory * 0.8 + alliesScore + country.leader.prestige * 1.4 + techScore;
    }

    function formatVictoryPath(path) {
      return path.replace(/victory/i, '勝利');
    }

    // ========== 勝利條件 ==========
    function checkVictory() {
      const alive = getAliveCountries();
      const totalTerritory = alive.reduce((sum, c) => sum + gameState.countryStats[c.name].territory, 0);
      const influenceScores = alive.map(c => ({ name: c.name, score: calculateInfluence(gameState.countryStats[c.name]) }));
      const maxInfluence = Math.max(...influenceScores.map(item => item.score));

      alive.forEach(c => {
        const state = gameState.countryStats[c.name];
        if (!state) return;
        if (!gameState.victoryCounters[c.name]) {
          gameState.victoryCounters[c.name] = { military: 0, economic: 0, diplomatic: 0, cultural: 0 };
        }

        // 世界征服勝利: 65% 領土 + 60月（真正形成霸權後才獲勝）
        if (totalTerritory > 0 && state.territory / totalTerritory > 0.65) {
          gameState.victoryCounters[c.name].military += 1;
        } else {
          gameState.victoryCounters[c.name].military = 0;
        }
        if (gameState.victoryCounters[c.name].military >= 60 && !gameState.victories[c.name]) {
          gameState.victories[c.name] = "世界征服";
          addNews(`${c.name}達成「世界征服」勝利！`);
          addChronicle(`${formatDateLabel()}：${c.name}征服世界，達成世界征服勝利！`);
          // 停止模擬並產生總結
          gameState.gameEnded = true;
          stopAutoRun();
          try { generateFinalSummary(); } catch(e) { console.error('生成總結錯誤', e); }
        }

        // 經濟勝利
        if (state.economy === Math.max(...alive.map(a => gameState.countryStats[a.name].economy))) {
          gameState.victoryCounters[c.name].economic += 1;
        } else {
          gameState.victoryCounters[c.name].economic = 0;
        }
        if (gameState.victoryCounters[c.name].economic >= 120 && !gameState.victories[c.name]) {
          gameState.victories[c.name] = "經濟勝利";
          addNews(`${c.name}達成「經濟勝利」！`);
          addChronicle(`${formatDateLabel()}：${c.name}因經濟繁榮達成經濟勝利！`);
          gameState.gameEnded = true;
          stopAutoRun();
          try { generateFinalSummary(); } catch(e) { console.error('生成總結錯誤', e); }
        }

        // 外交勝利: 60% 盟匡3 + 沒有敵人
        const neededAllies = Math.ceil(alive.length * 0.6);
        const hasEnemies = (state.enemies?.length || 0) > 0;
        if ((state.allies?.length || 0) >= neededAllies && !hasEnemies) {
          gameState.victoryCounters[c.name].diplomatic += 1;
        } else {
          gameState.victoryCounters[c.name].diplomatic = 0;
        }
        // 提升外交勝利所需持續月數 (60一是很严的門樄)
        if (gameState.victoryCounters[c.name].diplomatic >= 84 && !gameState.victories[c.name]) {
          gameState.victories[c.name] = "外交勝利";
          addNews(`${c.name}達成「外交勝利」！`);
          addChronicle(`${formatDateLabel()}：${c.name}通過外交聯盟達成外交勝利！`);
          gameState.gameEnded = true;
          stopAutoRun();
          try { generateFinalSummary(); } catch(e) { console.error('生成總結錯誤', e); }
        }

        // 文化影響力勝利
        const score = calculateInfluence(state);
        if (score >= maxInfluence * 0.95) {
          gameState.victoryCounters[c.name].cultural += 1;
        } else {
          gameState.victoryCounters[c.name].cultural = 0;
        }
        if (gameState.victoryCounters[c.name].cultural >= 144 && !gameState.victories[c.name]) {
          gameState.victories[c.name] = "文化勝利";
          addNews(`${c.name}達成「文化勝利」！`);
          addChronicle(`${formatDateLabel()}：${c.name}文化影響力遍布世界，達成文化勝利！`);
          gameState.gameEnded = true;
          stopAutoRun();
          try { generateFinalSummary(); } catch(e) { console.error('生成總結錯誤', e); }
        }

        // 科技勝利：>= 8 技術 且排名前3 且沒有敵人
        const techRanking = influenceScores.findIndex(item => item.name === c.name) + 1;
        const techHasNoEnemies = (state.enemies?.length || 0) === 0;
        if (state.researched_techs.length >= 8 && techRanking <= 3 && techHasNoEnemies && !gameState.victories[c.name]) {
          gameState.victories[c.name] = "科技勝利";
          addNews(`${c.name}達成「科技勝利」！`);
          addChronicle(`${formatDateLabel()}：${c.name}掌握全球高端科技，達成科技勝利！`);
          gameState.gameEnded = true;
          stopAutoRun();
          try { generateFinalSummary(); } catch(e) { console.error('生成總結錯誤', e); }
        }
      });
    }

    // ========== AI 戰略記憶 ==========
    function recordMemory(country, targetName, eventType, intensity) {
      if (!country.memory[targetName]) {
        country.memory[targetName] = { hatred: 0, trust: 0, wars: 0, alliances: 0 };
      }
      if (eventType === "war") {
        country.memory[targetName].hatred += intensity;
        country.memory[targetName].wars += 1;
      } else if (eventType === "alliance") {
        country.memory[targetName].trust += intensity;
        country.memory[targetName].alliances += 1;
      } else if (eventType === "betrayal") {
        country.memory[targetName].hatred += intensity * 2;
      }
    }

    // === AI 智能化系统 ===
    function shouldAIBuildWonder(country) {
      if (!country || country.status !== 'active') return false;
      if (country.economy < 80) return false;
      
      // 找出該國還未建的奇觀，且經濟適合
      const relevantWonders = WORLD_WONDERS.filter(w => 
        canBuildWonder(country, w.name)
      );
      
      if (relevantWonders.length === 0) return false;
      
      // 根據國家策略選擇適合的奇觀
      const trait = country.civilizationTrait;
      let scoredWonders = relevantWonders.map(w => {
        let score = 0;
        
        // 文明特質最佳化
        if (trait.bonus.soldiers && w.effects.defense) score += 20;
        if (trait.bonus.economy && w.effects.economy) score += 20;
        if (trait.bonus.research_speed && w.effects.research_speed) score += 20;
        
        // 策略適配
        if (country.strategy === 'aggressive' && w.effects.defense) score += 15;
        if (country.strategy === 'economic' && w.effects.economy) score += 15;
        if (country.strategy === 'diplomatic' && w.effects.cultural_integration) score += 15;
        
        // 國家現狀
        if (country.war_exhaustion > 60 && w.effects.stability) score += 10;
        if (country.satisfaction < 50 && w.effects.satisfaction) score += 10;
        
        return { wonder: w, score: score };
      }).sort((a, b) => b.score - a.score);
      
      // 有好的奇觀且經濟足夠，就建造 (30% 概率)
      return scoredWonders[0] && Math.random() < 0.3;
    }
    
    // === 動態目標系統 ===
    function reassessLongTermGoal(country) {
      if (!country || country.status !== 'active') return country.long_term_goal;
      
      const ranking = computeWorldRanking();
      const position = ranking.findIndex(r => r.name === country.name) + 1;
      const topCountry = ranking[0];
      const trait = country.civilizationTrait;
      
      // 第一名 → 維持霸權
      if (position === 1) {
        return '維持霸權';
      }
      
      // 前三名但有強敵 → 結盟抗衡
      if (position <= 3 && topCountry.power > ranking[position - 1].power * 1.4) {
        return '組建聯盟';
      }
      
      // 根據文明特質選擇最佳化目標
      if (trait.name === '軍國傳統' && position > 3) {
        return '軍事擴張';
      }
      if (trait.name === '海洋民族') {
        return '海洋霸權';
      }
      if (trait.name === '金融中心') {
        return '經濟稱霸';
      }
      if (trait.name === '科技先驅' && (country.researched_techs?.length || 0) < 5) {
        return '科技超越';
      }
      
      // 落後且不穩定 → 先求生存
      if (position > 5 && country.stability < 40) {
        return '獨立維持';
      }
      
      // 預設返回原目標
      return country.long_term_goal;
    }
    
    // === 黑暗時代系統（對標黃金時代）===
    function triggerDarkAge(country) {
      if (!country || country.status !== 'active') return false;
      if (country.darkAge && country.darkAge.inDarkAge) return false;  // 已在黑暗時代
      
      // 觸發條件：經濟低迷 + 戰爭疲勞高 + 腐敗嚴重 + 穩定度低
      const economyLow = country.economy < 5;
      const warExhausted = country.war_exhaustion > 70;
      const corruptionHigh = country.corruption > 60;
      const stabilityLow = country.stability < 40;
      
      if (economyLow && warExhausted && corruptionHigh && stabilityLow) {
        // 觸發黑暗時代
        if (!country.darkAge) {
          country.darkAge = {
            inDarkAge: false,
            duration: 0,
            economicLeaderMonths: 0
          };
        }
        
        country.darkAge.inDarkAge = true;
        country.darkAge.duration = Math.floor(Math.random() * 48 + 24);  // 24-72 月
        country.darkAge.startTurn = gameState.turn;
        
        addNews(`⚫ ${country.name} 陷入黑暗時代！經濟崩潰，人民苦難。`);
        addChronicle(`${formatDateLabel()}：${country.name} 陷入黑暗時代，持續約 ${country.darkAge.duration} 月。`);
        return true;
      }
      return false;
    }
    
    // 應用黑暗時代效果
    function applyDarkAgeEffects(country) {
      if (!country.darkAge || !country.darkAge.inDarkAge) return;
      
      country.darkAge.duration -= 1;
      
      // 黑暗時代效果
      // 經濟衰退 -40%
      country.economy *= 0.6;
      
      // 人口下降 -20% per month
      country.population = Math.max(10, country.population * 0.98);
      
      // 人口滿意度大幅下降
      country.satisfaction = Math.max(0, country.satisfaction - 3);
      
      // 叛亂風險增加
      if (Math.random() < 0.08) {
        addNews(`⚠️ ${country.name} 因黑暗時代爆發起義！`);
        country.soldiers = Math.max(50, country.soldiers * 0.85);
      }
      
      // 領土可能喪失 (非常小的概率)
      if (Math.random() < 0.02 && country.territory > 5) {
        const lostTerritory = Math.max(1, Math.floor(country.territory * 0.05));
        addNews(`${country.name} 失去控制 ${lostTerritory} 格領土。`);
      }
      
      // 腐敗進一步增加
      country.corruption = Math.min(100, country.corruption + 2);
      
      // 黑暗時代結束檢查
      if (country.darkAge.duration <= 0) {
        country.darkAge.inDarkAge = false;
        addNews(`${country.name} 走出黑暗時代，迎接新生。`);
        // 走出黑暗時代後經濟小幅恢復
